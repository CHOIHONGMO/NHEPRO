<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.eversrm.eApproval.eApprovalEnd.AP.EApprovalEndAp_Mapper">
	
	<!-- 2021.05.10 변경 : 대금지급대상 가져오기 -->
    <select id="getApNum" parameterType="hashMap" resultType="hashmap">
        SELECT
        	  IVAP.AP_NUM
            , IVAP.INV_NUM
            , IVAP.PO_NUM
            , IVAP.DEPT_CD
            , IVAP.PAY_CNT
            , IVAP.PY_BUYER_CD
            , IVAP.PY_DEPT_CD
        FROM STOCIVAP IVAP
        LEFT JOIN STOCIVHD IVHD
             ON (IVHD.GATE_CD  = IVAP.GATE_CD
             AND IVHD.BUYER_CD = IVAP.BUYER_CD
             AND IVHD.INV_NUM  = IVAP.INV_NUM
             AND IVHD.DEL_FLAG = '0')
        WHERE IVAP.GATE_CD  = #{ses.gateCd}
          AND IVAP.BUYER_CD = #{BUYER_CD}
          AND IVAP.APP_DOC_NUM = #{APP_DOC_NUM}
          AND IVAP.APP_DOC_CNT = #{APP_DOC_CNT}
          AND IVAP.DEL_FLAG = '0'
        GROUP BY IVAP.AP_NUM
	           , IVAP.INV_NUM
	           , IVAP.PO_NUM
	           , IVAP.DEPT_CD
	           , IVAP.PAY_CNT
	           , IVAP.PY_BUYER_CD
	           , IVAP.PY_DEPT_CD
    </select>
	
    <select id="getApList" parameterType="hashMap" resultType="hashmap">
    	SELECT
        	  IVAP.BUYER_CD
            , IVAP.AP_NUM
            , IVDT.INV_NUM
            , IVDT.INV_SQ
            , IVDT.PO_NUM
            , IVDT.PO_SQ
        FROM STOCIVAP IVAP
        LEFT JOIN STOCIVHD IVHD
             ON (IVHD.GATE_CD  = IVAP.GATE_CD
             AND IVHD.BUYER_CD = IVAP.BUYER_CD
             AND IVHD.INV_NUM  = IVAP.INV_NUM
             AND IVHD.DEL_FLAG = '0')
        LEFT JOIN STOCIVDT IVDT
             ON (IVDT.GATE_CD  = IVHD.GATE_CD
             AND IVDT.BUYER_CD = IVHD.BUYER_CD
             AND IVDT.INV_NUM  = IVHD.INV_NUM
             AND IVDT.DEL_FLAG = '0')
        WHERE IVAP.GATE_CD  = #{ses.gateCd}
          AND IVAP.BUYER_CD = #{BUYER_CD}
          AND IVAP.APP_DOC_NUM = #{APP_DOC_NUM}
          AND IVAP.APP_DOC_CNT = #{APP_DOC_CNT}
          AND IVAP.DEL_FLAG = '0'
    </select>
	
	<!-- 2021.05.10 변경 -->
	<!-- 1. 대금지급담당자의 고객사에게 수수료 부과하기 -->
	<!-- 2. 대금지급 결재 승인 후 요청 협력사에게 메일, SMS 보내기 -->
    <select id="getMailList" parameterType="hashMap" resultType="hashMap">
        SELECT
        	  IVAP.AP_NUM
            , POHD.PO_NUM
            , POHD.SUBJECT
            , IVAP.BUYER_CD
            ,<include refid="common.sql.dbo"/>GETCOMPANYNAME(IVAP.GATE_CD, IVAP.BUYER_CD, #{ses.langCd}) AS BUYER_NM
            , IVHD.VENDOR_CD AS RECV_USER_ID
            ,<include refid="common.sql.dbo"/>GETCOMPANYNAME(POHD.GATE_CD, POHD.VENDOR_CD, #{ses.langCd}) AS VENDOR_NM
            ,<include refid="common.sql.strDecStart"/>IVAP.VENDOR_USER_NM<include refid="common.sql.strDecEnd"/> AS USER_NM
            ,<include refid="common.sql.strDecStart"/>IVAP.VENDOR_CELL_NUM<include refid="common.sql.strDecEnd"/> AS CELL_NUM
            , IVAP.AP_REQ_SUBJECT
            ,<include refid="common.sql.toChar"/>(IVAP.AP_REQ_DATE, 'YYYY-MM-DD') AS AP_REQ_DATE
            , IVAP.PAY_CNT
            , IVPC.PAY_CNT_NM <include refid="common.sql.stringMerge"/> ' ' <include refid="common.sql.stringMerge"/> IVAP.PAY_CNT AS PAY_CNT_INFO
            , IVAP.AP_AMT
            ,<include refid="common.sql.toChar"/>(IVHD.SIGN_DATE, 'YYYY-MM-DD') AS SIGN_DATE
            ,<include refid="common.sql.nvl"/>(IVAP.AP_USER_ID, POHD.CTRL_USER_ID) AS AP_USER_ID
        FROM STOCIVAP IVAP
        LEFT JOIN STOCIVHD IVHD
             ON (IVHD.GATE_CD  = IVAP.GATE_CD
             AND IVHD.BUYER_CD = IVAP.BUYER_CD
             AND IVHD.INV_NUM  = IVAP.INV_NUM
             AND IVHD.DEL_FLAG = '0')
        LEFT JOIN STOCIVPC IVPC
             ON (IVPC.GATE_CD  = IVAP.GATE_CD
             AND IVPC.BUYER_CD = IVAP.BUYER_CD
             AND IVPC.DEPT_CD  = IVAP.DEPT_CD
             AND IVPC.INV_NUM  = IVAP.INV_NUM
             AND IVPC.PAY_CNT  = IVAP.PAY_CNT
             AND IVPC.PY_BUYER_CD = IVAP.PY_BUYER_CD
             AND IVPC.PY_DEPT_CD  = IVAP.PY_DEPT_CD
             AND IVPC.PO_NUM   = IVAP.PO_NUM
             AND IVPC.DEL_FLAG = '0')
        LEFT JOIN STOCPOHD POHD
             ON (POHD.GATE_CD  = IVAP.GATE_CD
             AND POHD.BUYER_CD = IVAP.BUYER_CD
             AND POHD.PO_NUM   = IVAP.PO_NUM
             AND POHD.DEL_FLAG = '0')
        WHERE IVAP.GATE_CD     = #{ses.gateCd}
          AND IVAP.BUYER_CD    = #{BUYER_CD}
          AND IVAP.AP_NUM      = #{AP_NUM}
          AND IVAP.INV_NUM     = #{INV_NUM}
          AND IVAP.PO_NUM      = #{PO_NUM}
          AND IVAP.PAY_CNT     = #{PAY_CNT}
          AND IVAP.PY_BUYER_CD = #{PY_BUYER_CD}
          AND IVAP.PY_DEPT_CD  = #{PY_DEPT_CD}
    </select>
	
	<!-- 2021.05.10 변경 -->
	<!-- 협력사의 대금지급 요청건을 고객사에서 결재승인 후 고객사에 수수료 부과 -->
	<!-- 대금지급담당자가 있으면 대금지급담당자 고객사, 없으면 결재자의 고객사 -->
    <select id="costSmsInfo" parameterType="hashMap" resultType="hashMap">
        SELECT CUST.IRS_NUM 	AS CORP_NO
             , CVUR.DEPT_CD 	AS BRC
             , <include refid="common.sql.toChar"/>(SYSDATE, 'YYYYMMDD') AS APLY_DT
             , CVUR.USER_ID 	AS USER_ID
             , 'SMS_AP'		<include refid="common.sql.stringMerge"/> '@@' <include refid="common.sql.stringMerge"/>
               CUST.GATE_CD <include refid="common.sql.stringMerge"/> '@@' <include refid="common.sql.stringMerge"/>
               CUST.CUST_CD <include refid="common.sql.stringMerge"/> '@@' <include refid="common.sql.stringMerge"/>
               #{AP_NUM}    	AS CONT_TBL_PK
             , NULL         	AS FILE_SIZE
         FROM STOCCVUR CVUR
         JOIN STOCCUST CUST
              ON (CUST.GATE_CD = CVUR.GATE_CD
              AND CUST.CUST_CD = CVUR.COMPANY_CD)
        WHERE CVUR.GATE_CD = #{ses.gateCd}
          AND CVUR.USER_ID = <include refid="common.sql.nvl"/>(#{AP_USER_ID}, #{ses.userId})
    </select>

    <update id="setApSignStatusIVAP" parameterType="hashmap">
        UPDATE STOCIVAP SET
              APP_DOC_SIGN_STATUS = #{SIGN_STATUS}
		<if test='SIGN_STATUS == "E" or SIGN_STATUS == "R"'>
            , SIGN_DATE = SYSDATE
		</if>
		<!-- 대금지급에서는 SIGN_STATUS가 진행상태코드 컬럼으로 사용함  -->
		<if test='PROGRESS_CD != "" and PROGRESS_CD != null'>
            , SIGN_STATUS = #{PROGRESS_CD}
		</if>
        WHERE GATE_CD  = #{ses.gateCd}
          AND BUYER_CD = #{BUYER_CD}
          AND AP_NUM   = #{AP_NUM}
    </update>
	
	<!-- 발주진행상태 변경=8100(정산중) -->
    <update id="setApSignStatusPODT" parameterType="hashmap">
        UPDATE STOCPODT SET
            PROGRESS_CD = #{PROGRESS_CD}
         WHERE GATE_CD  = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND PO_NUM   = #{PO_NUM}
           AND PO_SQ    = #{PO_SQ}
    </update>

</mapper>