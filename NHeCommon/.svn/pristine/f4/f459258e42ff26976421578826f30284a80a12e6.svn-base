<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.common.util.EverDateMapper">

    <select id="getCurrentServerTime" parameterType="hashMap" resultType="Date">

        SELECT SYSDATE <include refid="common.sql.dual"/>

    </select>

	<select id="getWorkingDay" parameterType="hashMap" resultType="java.lang.String">

		SELECT <include refid="common.sql.dbo"/>GETWORKINGDAY(#{PARAM_DAY}) <include refid="common.sql.dual"/>

	</select>

</mapper>
