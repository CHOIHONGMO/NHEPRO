<!--<?xml version="1.0" encoding="ISO-8859-1"?>-->
<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE web-app
    PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
    "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
  <display-name>Welcome to Tomcat</display-name>
  <description>
     Welcome to Tomcat
  </description>

    <servlet>
        <servlet-name>org.apache.jsp.index_jsp</servlet-name>
        <servlet-class>org.apache.jsp.index_jsp</servlet-class>
    </servlet>

  <servlet>
    <servlet-name>SendServlet</servlet-name>
    <display-name>SendServlet</display-name>
    <servlet-class>SendServlet</servlet-class>
	<init-param>
            <param-name>KICA.SGIxLinker.CONF</param-name>
            <param-value>/SGIxLinker/conf/sendinfo.properties</param-value>
    </init-param>
    <load-on-startup>1</load-on-startup>
  </servlet>

  <servlet>
    <servlet-name>RecvServlet</servlet-name>
    <display-name>RecvServlet</display-name>
    <servlet-class>RecvServlet</servlet-class>
	<init-param>
            <param-name>KICA.SGIxLinker.CONF</param-name>
            <param-value>/SGIxLinker/conf/recvinfo.properties</param-value>
    </init-param>
    <load-on-startup>1</load-on-startup>
  </servlet>

  <servlet-mapping>
    <servlet-name>SendServlet</servlet-name>
    <url-pattern>/servlet/SendServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>RecvServlet</servlet-name>
    <url-pattern>/servlet/RecvServlet</url-pattern>
  </servlet-mapping>
  
  </web-app>
