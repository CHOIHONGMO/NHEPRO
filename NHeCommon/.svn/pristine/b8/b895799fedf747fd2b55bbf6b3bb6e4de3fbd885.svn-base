<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.eversrm.manager.auth.MAUB0010_Mapper">

	<select id="doSelect" parameterType="hashmap" resultType="hashmap">

		SELECT
			  BACH.CH_TYPE
			, BACH.SEQ
			, BACH.CTRL_CD
			, BACH.CTRL_USER_ID AS CTRL_USER_ID
			, USR.EMPLOYEE_NUM AS EMPLOYEE_NUM
			, (CASE WHEN BACH.USE_FLAG = '1' THEN 'Y' ELSE 'N' END) AS USE_FLAG
			, <include refid="common.sql.dbo"/>GETCTRLNAME(BACH.GATE_CD, BACH.BUYER_CD, BACH.CTRL_CD, #{ses.langCd}) AS CTRL_NM
			, <include refid="common.sql.dbo"/>GETUSERNAME(BACH.GATE_CD, BACH.CTRL_USER_ID, #{ses.langCd}) AS USER_NM
			, <include refid="common.sql.dbo"/>getDeptName(USR.GATE_CD, USR.COMPANY_CD, USR.DEPT_CD, #{ses.langCd}) AS DEPT_NM
			, <include refid="common.sql.dbo"/>GETUSERNAME(BACH.GATE_CD, BACH.MOD_USER_ID, #{ses.langCd}) AS MOD_USER_NM
			, <include refid="common.sql.toChar"/>(BACH.MOD_DATE, 'YYYY-MM-DD HH24:MI') AS MOD_DATE
		  FROM STOCBACH BACH
		  LEFT OUTER JOIN STOCUSER USR
		   ON (BACH.GATE_CD = USR.GATE_CD
		   AND BACH.CTRL_USER_ID = USR.USER_ID
		   AND USR.DEL_FLAG = '0')
		  LEFT OUTER JOIN STOCBACO BACO
		   ON (BACH.GATE_CD = BACO.GATE_CD
		   AND BACH.BUYER_CD = BACO.BUYER_CD
		   AND BACH.CTRL_CD = BACO.CTRL_CD
		   AND BACO.DEL_FLAG = '0')
		 WHERE BACH.GATE_CD = #{ses.gateCd}
		   AND BACH.DEL_FLAG = '0'
		<if test="buyerCd != '' and buyerCd != null">
		   AND BACH.BUYER_CD = #{buyerCd}
		</if>
		<if test="CTRL_NM != '' and CTRL_NM != null">
           AND
           <foreach item="item" index="index" collection="CTRL_NM_LIST" open="(" separator="" close=")">
           	   <if test="index == 0">
           	   	   BACO.CTRL_NM LIKE '%' <include refid="common.sql.stringMerge"/> #{item} <include refid="common.sql.stringMerge"/> '%'
           	   </if>
           	   <if test="index != 0">
           	   	   OR BACO.CTRL_NM LIKE '%' <include refid="common.sql.stringMerge"/> #{item} <include refid="common.sql.stringMerge"/> '%'
           	   </if>
			</foreach>
		</if>
		<if test="USER_NM != '' and USER_NM != null">
		   AND UPPER(<include refid="common.sql.strDecStart"/>USR.USER_NM<include refid="common.sql.strDecEnd"/>) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{USER_NM}) <include refid="common.sql.stringMerge"/> '%'
		</if>
		<if test="USER_ID != '' and USER_ID != null">
		   AND UPPER(USR.USER_ID) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{USER_ID}) <include refid="common.sql.stringMerge"/> '%'
		</if>
		<if test="MOD_FROM_DATE != '' and MOD_FROM_DATE != null">
		   AND BACH.MOD_DATE <![CDATA[>=]]> <include refid="common.sql.toDateFrom"/>(#{MOD_FROM_DATE})
		</if>
		<if test="MOD_TO_DATE != '' and MOD_TO_DATE != null">
		   AND BACH.MOD_DATE <![CDATA[<=]]> <include refid="common.sql.toDateTo"/>(#{MOD_TO_DATE})
		</if>
		 ORDER BY BACH.CTRL_CD, USR.USER_NM, BACH.SEQ DESC

	</select>

</mapper>