<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.eversrm.manager.auth.MAUA0010_Mapper">

	<select id="selectTaskCode" parameterType="hashmap" resultType="hashmap">

		SELECT
			 BACO.GATE_CD
			,BACO.BUYER_CD
			,BACO.BUYER_CD AS BUYER_CD_ORI
			,BACO.PUR_ORG_CD
			,<include refid="common.sql.dbo"/>GETBUYERNAME(BACO.GATE_CD, BACO.BUYER_CD, #{ses.langCd}) AS BUYER_NM
			,<include refid="common.sql.dbo"/>GETPURORGNAME(BACO.GATE_CD, BACO.BUYER_CD, BACO.PUR_ORG_CD, #{ses.langCd}) AS PUR_ORG_NM
			,BACO.CTRL_CD
			,BACO.CTRL_CD AS CTRL_CD_ORI
			,BACO.CTRL_NM
			,BACO.CTRL_NM_ENG
			,BACO.COMPANY_TYPE
			,BACO.CTRL_TYPE
			,BACO.USE_FLAG
			,'U' AS INSERT_FLAG
			,(SELECT COUNT(CTRL_CD) FROM STOCBAMT WHERE GATE_CD = BACO.GATE_CD AND BUYER_CD = BACO.BUYER_CD AND CTRL_CD = BACO.CTRL_CD AND DEL_FLAG = '0') AS MAPPING_ITEMS
			,(SELECT COUNT(CTRL_CD) FROM STOCBACP WHERE GATE_CD = BACO.GATE_CD AND BUYER_CD = BACO.BUYER_CD AND CTRL_CD = BACO.CTRL_CD AND DEL_FLAG = '0') AS PIC_NUMBER
			,BACO.SORT_SQ
		FROM STOCBACO BACO
		LEFT OUTER JOIN STOCOGPU OGPU
		 ON (BACO.GATE_CD = OGPU.GATE_CD
		 AND BACO.BUYER_CD = OGPU.BUYER_CD
		 AND BACO.PUR_ORG_CD = OGPU.PUR_ORG_CD
		 AND OGPU.DEL_FLAG = '0')
		JOIN STOCOGCM OGCM
		 ON (BACO.GATE_CD = OGCM.GATE_CD
		 AND BACO.BUYER_CD = OGCM.BUYER_CD)
		WHERE BACO.GATE_CD = #{ses.gateCd}
		  AND BACO.DEL_FLAG = '0'
		  AND OGCM.DEL_FLAG = '0'
		<if test="BUYER_CD != '' and BUYER_CD != null">
			AND BACO.BUYER_CD = #{BUYER_CD}
		</if>
		<if test="CTRL_TYPE != '' and CTRL_TYPE != null">
			AND BACO.CTRL_TYPE = #{CTRL_TYPE}
		</if>
		<if test="CTRL_CD != '' and CTRL_CD != null">
			AND UPPER(BACO.CTRL_CD) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{CTRL_CD}) <include refid="common.sql.stringMerge"/> '%'
		</if>
		<if test="CTRL_NM != '' and CTRL_NM != null">
			AND UPPER(BACO.CTRL_NM) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{CTRL_NM}) <include refid="common.sql.stringMerge"/> '%'
		</if>
		ORDER BY BACO.COMPANY_TYPE,BACO.CTRL_CD, BACO.SORT_SQ

	</select>

	<select id="selectMappingUser_add" parameterType="hashmap" resultType="hashmap">

		SELECT
			 <include refid="common.sql.dbo"/>GETUSERINFO(BACP.GATE_CD, BACP.CTRL_USER_ID, 'USER_NM') AS USER_NM
			,BACP.CTRL_USER_ID AS USER_ID
			,BACP.CTRL_USER_ID AS USER_ID_V
			,<include refid="common.sql.dbo"/>GETUSERINFO(BACP.GATE_CD, BACP.CTRL_USER_ID, 'EMPLOYEE_NUM') AS EMPLOYEE_NUM
			,BACP.USE_FLAG
			,<include refid="common.sql.dbo"/>getDeptName(BACP.GATE_CD, BACP.BUYER_CD, <include refid="common.sql.dbo"/>GETUSERINFO(BACP.GATE_CD, BACP.CTRL_USER_ID, 'DEPT_CD'), #{ses.langCd}) AS DEPT_NM
			,<include refid="common.sql.dbo"/>getUserName(BACP.GATE_CD, BACP.MOD_USER_ID, #{ses.langCd}) AS US_MOD_USER_NM
			,BACP.MOD_DATE AS US_MOD_INFO
			,BACP.BUYER_CD
			, GETCOMPANYNAME(BACP.GATE_CD, BACP.BUYER_CD, 'KO') AS BUYER_NM
		  FROM STOCBACP BACP
		 WHERE BACP.GATE_CD = #{ses.gateCd}
		   AND BACP.DEL_FLAG = '0'
		   AND BACP.CTRL_CD = #{CTRL_CD_S}
		 ORDER BY BACP.CTRL_USER_ID

	</select>

	<select id="checkTaskCode" parameterType="hashMap" resultType="java.lang.Integer">

		SELECT COUNT(CTRL_CD)
		  FROM STOCBACO
		 WHERE GATE_CD = #{GATE_CD}
		   AND BUYER_CD = #{BUYER_CD}
		   AND CTRL_CD = #{CTRL_CD}

	</select>

	<insert id="insertTaskCode" parameterType="hashmap">

		INSERT INTO STOCBACO (
			  REG_DATE
			, REG_USER_ID
			, MOD_DATE
			, MOD_USER_ID
			, GATE_CD
			, BUYER_CD
			, CTRL_CD
			, CTRL_TYPE
			, CTRL_NM
			, CTRL_NM_ENG
			, PUR_ORG_CD
			, DEL_FLAG
			, USE_FLAG
			, SORT_SQ
			, COMPANY_TYPE
		)
		VALUES (
			  SYSDATE
			, #{ses.userId}
			, SYSDATE
			, #{ses.userId}
			, #{GATE_CD}
			, #{BUYER_CD}
			, #{CTRL_CD}
			, #{CTRL_TYPE}
			, #{CTRL_NM}
			, #{CTRL_NM_ENG}
			, #{PUR_ORG_CD}
			, '0'
			, #{USE_FLAG}
			, #{SORT_SQ}
			, #{COMPANY_TYPE}
		)

	</insert>

	<update id="updateTaskCode" parameterType="hashmap">

		UPDATE STOCBACO SET
			  MOD_USER_ID = #{ses.userId}
			, MOD_DATE = SYSDATE
			, DEL_FLAG = '0'
			, CTRL_TYPE = #{CTRL_TYPE}
			, CTRL_NM = #{CTRL_NM}
			, CTRL_NM_ENG = #{CTRL_NM_ENG}
			, COMPANY_TYPE = #{COMPANY_TYPE}
			, PUR_ORG_CD = #{PUR_ORG_CD}
			, SORT_SQ = #{SORT_SQ}
			, USE_FLAG = #{USE_FLAG}
		 WHERE GATE_CD = #{GATE_CD}
		   AND BUYER_CD = #{BUYER_CD}
		   AND CTRL_CD = #{CTRL_CD}

	</update>

	<update id="deleteTaskCode" parameterType="hashmap">

		UPDATE STOCBACO SET
			  DEL_FLAG = '1'
			, MOD_USER_ID = #{ses.userId}
			, MOD_DATE = SYSDATE
		 WHERE GATE_CD = #{GATE_CD}
		   AND BUYER_CD = #{BUYER_CD_ORI}
		   AND CTRL_CD = #{CTRL_CD_ORI}

	</update>

	<select id="checkTaskPersonInCharge" parameterType="hashmap" resultType="java.lang.Integer">

		SELECT <include refid="common.sql.mtop1"/>
			COUNT(CTRL_CD) AS CNT
		  FROM STOCBACP
		 WHERE GATE_CD = #{ses.gateCd}
		   AND BUYER_CD = #{BUYER_CD}
		   AND CTRL_CD = #{CTRL_CD}
		   AND CTRL_USER_ID = #{CTRL_USER_ID}
		   <include refid="common.sql.otop1"/>

	</select>

	<insert id="insertTaskPersonInCharge" parameterType="hashmap">

		INSERT INTO STOCBACP (
			  REG_DATE
			, REG_USER_ID
			, MOD_DATE
			, MOD_USER_ID
			, GATE_CD
			, BUYER_CD
			, CTRL_CD
			, CTRL_USER_ID
			, DEL_FLAG
			, USE_FLAG
		) SELECT
			  SYSDATE
			, #{ses.userId}
			, SYSDATE
			, #{ses.userId}
			, #{ses.gateCd}
			, #{BUYER_CD}
			, #{CTRL_CD}
			, #{CTRL_USER_ID}
			, '0'
			, #{USE_FLAG}
		  FROM DUAL
		  WHERE NOT EXISTS (
					SELECT '1' FROM STOCBACP
					WHERE GATE_CD  = #{ses.gateCd}
					  AND BUYER_CD = #{BUYER_CD}
					  AND CTRL_CD  = #{CTRL_CD}
					  AND CTRL_USER_ID = #{CTRL_USER_ID}
		  		)
	</insert>

	<!-- 직무-담당자 변경 -->
	<update id="updateTaskPersonInCharge" parameterType="hashmap">

		UPDATE STOCBACP SET
			  MOD_USER_ID = #{ses.userId}
			, MOD_DATE = SYSDATE
			, DEL_FLAG = '0'
		<if test="USE_FLAG != '' and USE_FLAG != null">
			, USE_FLAG = #{USE_FLAG}
		</if>
		 WHERE GATE_CD  = #{ses.gateCd}
		   AND BUYER_CD = #{BUYER_CD}
		   AND CTRL_USER_ID = #{CTRL_USER_ID}
		   AND CTRL_CD  = #{CTRL_CD}
	</update>

	<!-- BR100 : 고객사 관리자 직무인 경우 STOCCVUR의 MNG_YN = '1'로 변경 -->
	<update id="updateCustomerMngYn" parameterType="hashmap">

		UPDATE STOCCVUR SET
			   MNG_YN   = (CASE WHEN <include refid="common.sql.nvl"/>(#{DEL_FLAG}, '0') = '1' THEN '0'
			                    ELSE (CASE WHEN <include refid="common.sql.nvl"/>(#{USE_FLAG},'0') = '1' THEN '1'
			                               ELSE '0'
			                          END)
			               END)
		 WHERE GATE_CD   = #{ses.gateCd}
		   AND USER_ID   = (CASE WHEN <include refid="common.sql.nvl"/>(#{CTRL_USER_ID},'X') = 'X' THEN #{CTRL_USER_ID_ORI} ELSE #{CTRL_USER_ID} END)
		   AND USER_TYPE = 'B'
		   AND DEL_FLAG  = '0'
	</update>

	<insert id="saveHistoryBACH" parameterType="hashmap">

		INSERT INTO STOCBACH (
			  GATE_CD
			, BUYER_CD
			, CTRL_CD
			, CTRL_USER_ID
			, SEQ
			, REG_DATE
			, REG_USER_ID
			, MOD_DATE
			, MOD_USER_ID
			, CH_TYPE
			, DEL_FLAG
			, USE_FLAG
		)
		VALUES (
			  #{ses.gateCd}
			, #{BUYER_CD}
			, #{CTRL_CD}
			, #{CTRL_USER_ID}
			, <include refid="common.sql.nvl"/>((SELECT MAX(SEQ)
			         FROM STOCBACH
					WHERE GATE_CD  = #{ses.gateCd}
					  AND BUYER_CD = #{BUYER_CD}
					  AND CTRL_CD  = #{CTRL_CD}
					  AND CTRL_USER_ID = #{CTRL_USER_ID}), 0) + 1
			, SYSDATE
			, #{ses.userId}
			, SYSDATE
			, #{ses.userId}
			, #{CH_TYPE}
			, '0'
			, #{USE_FLAG}
		)
	</insert>

	<update id="deleteTaskPersonInCharge" parameterType="hashmap">

		UPDATE STOCBACP SET
			  DEL_FLAG = '1'
			, MOD_USER_ID = #{ses.userId}
			, MOD_DATE = SYSDATE
		 WHERE GATE_CD  = #{ses.gateCd}
		   AND BUYER_CD = #{BUYER_CD_BACP}
		   AND CTRL_USER_ID = #{CTRL_USER_ID_ORI}
		   AND CTRL_CD  = #{CTRL_CD_ORI}
	</update>

	<update id="deleteTaskPersonInCharge2" parameterType="hashmap">

		UPDATE STOCBACP SET
			  DEL_FLAG = '1'
			, MOD_USER_ID = #{ses.userId}
			, MOD_DATE = SYSDATE
		 WHERE GATE_CD  = #{ses.gateCd}
		   AND BUYER_CD = #{BUYER_CD}
		   AND CTRL_CD  = #{CTRL_CD}
	</update>

	<insert id="saveHistoryBACH2" parameterType="hashmap">

		INSERT INTO STOCBACH (
			  GATE_CD
			, BUYER_CD
			, CTRL_CD
			, CTRL_USER_ID
			, SEQ
			, REG_DATE
			, REG_USER_ID
			, MOD_DATE
			, MOD_USER_ID
			, CH_TYPE
			, DEL_FLAG
			, USE_FLAG
		)
		SELECT
			  #{ses.gateCd}
			, #{BUYER_CD}
			, #{CTRL_CD}
			, CTRL_USER_ID
			, <include refid="common.sql.nvl"/>((SELECT MAX(SEQ)
					 FROM STOCBACH
					WHERE GATE_CD = #{ses.gateCd}
					  AND BUYER_CD = #{BUYER_CD}
					  AND CTRL_CD = #{CTRL_CD}),0) + ROW_NUMBER() OVER( ORDER BY CTRL_USER_ID DESC)
			, SYSDATE
			, #{ses.userId}
			, SYSDATE
			, #{ses.userId}
			, #{CH_TYPE}
			, '0'
			, #{USE_FLAG}
		 FROM STOCBACP
		WHERE GATE_CD = #{ses.gateCd}
		  AND BUYER_CD = #{BUYER_CD}
		  AND CTRL_CD = #{CTRL_CD}

	</insert>

</mapper>