				<col style="width:254px">
				<col style="width:142px">
				<col>
			</colgroup>
			<tbody>
			<tr>
				<th style='vertical-align: top;border-bottom:1px solid #b8b8b8;border-left:1px solid #cdcdcd;border-right:1px solid #cdcdcd;padding:8px 0 8px 20px;text-align:left;font-size:12px;color:#404141;background:#eeeeee url($maintainUrl$/images/ymro/mail/ico_title2.gif) 8px 12px no-repeat'>견적의뢰번호/차수</th>
				<td style='word-break:break-all;border-left:1px solid #cdcdcd;border-right:1px solid #cdcdcd;border-bottom:1px solid #cdcdcd;text-align:left;padding-left:6px;color:#404141;font-size:12px;vertical-align: middle;' >$RFQ_NUM_CNT$</td>
				<th style='vertical-align: top;border-bottom:1px solid #b8b8b8;border-left:1px solid #cdcdcd;border-right:1px solid #cdcdcd;padding:8px 0 8px 20px;text-align:left;font-size:12px;color:#404141;background:#eeeeee url($maintainUrl$/images/ymro/mail/ico_title2.gif) 8px 12px no-repeat'>견적의뢰명</th>
				<td style='word-break:break-all;border-left:1px solid #cdcdcd;border-right:1px solid #cdcdcd;border-bottom:1px solid #cdcdcd;text-align:left;padding-left:6px;color:#404141;font-size:12px;vertical-align: middle;' >$RFQ_SUBJECT$</td>
			</tr>
			<tr>
				<th style='vertical-align: top;border-bottom:1px solid #b8b8b8;border-left:1px solid #cdcdcd;border-right:1px solid #cdcdcd;padding:8px 0 8px 20px;text-align:left;font-size:12px;color:#404141;background:#eeeeee url($maintainUrl$/images/ymro/mail/ico_title2.gif) 8px 12px no-repeat'>견적마감일시</th>
				<td style='word-break:break-all;border-left:1px solid #cdcdcd;border-right:1px solid #cdcdcd;border-bottom:1px solid #cdcdcd;text-align:left;padding-left:6px;color:#404141;font-size:12px'>$RFQ_CLOSE_DATE$</td>
