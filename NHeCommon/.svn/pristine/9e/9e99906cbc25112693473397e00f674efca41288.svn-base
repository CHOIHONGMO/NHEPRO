<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.eversrm.manager.auth.MAUA0050_Mapper">

    <select id="MAUA0050_doSearch" parameterType="hashmap" resultType="hashmap">

        SELECT A.*
          FROM (
                SELECT EC.ECCD_NUM
                     , EC.BUYER_CD
                     , EC.FORM_ROLE_TYPE
                     , EC.DEPT_CD
                     , EC.USE_FLAG
                     , <include refid="common.sql.dbo"/>getDeptName(EC.GATE_CD, EC.BUYER_CD, EC.DEPT_CD, #{ses.langCd}) AS DEPT_NM
                     , CONVERT(NUMERIC, OG.EXT_ORDER) AS EXT_ORDER
                  FROM STOCECCD EC
                  JOIN STOCOGDP OG
                    ON (EC.GATE_CD = OG.GATE_CD
                   AND EC.BUYER_CD = OG.BUYER_CD
                   AND EC.DEPT_CD = OG.DEPT_CD
                   AND OG.DEL_FLAG = '0')
                 WHERE EC.GATE_CD = #{ses.gateCd}
                   AND EC.DEL_FLAG = '0'
               ) A
         WHERE 1=1
        <if test="BUYER_CD != null and BUYER_CD != ''">
           AND A.BUYER_CD = #{BUYER_CD}
        </if>
        <if test="DEPT_NM != null and DEPT_NM != ''">
           AND UPPER(A.DEPT_NM) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{DEPT_NM}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="FORM_ROLE_TYPE != null and FORM_ROLE_TYPE != ''">
           AND A.FORM_ROLE_TYPE = #{FORM_ROLE_TYPE}
        </if>
         ORDER BY A.EXT_ORDER

    </select>

    <update id="MAUA0050_doSave" parameterType="hashmap">

        MERGE <include refid="common.sql.mergeInto"/> STOCECCD ECD
        USING (SELECT #{ses.gateCd} AS GATE_CD
                    , #{ECCD_NUM} AS ECCD_NUM
              ) TDT
           ON (ECD.GATE_CD = TDT.GATE_CD
          AND ECD.ECCD_NUM = TDT.ECCD_NUM)

         WHEN NOT MATCHED
         THEN INSERT (
              GATE_CD
            , ECCD_NUM
            , BUYER_CD
            , FORM_ROLE_TYPE
            , DEPT_CD
            , REG_DATE
            , REG_USER_ID
            , DEL_FLAG
            , USE_FLAG
        ) VALUES (
              #{ses.gateCd}
        <if test="_databaseId == 'oracle'">
            , (SELECT <include refid="common.sql.nvl"/>(MAX(TO_NUMBER(ECCD_NUM) )+1, '1')
                 FROM STOCECCD
                WHERE GATE_CD = #{ses.gateCd})
		</if>
		<if test="_databaseId == 'mssql'">
            , (SELECT <include refid="common.sql.nvl"/>(MAX(CONVERT(NUMERIC, ECCD_NUM))+1, '1')
                 FROM STOCECCD
                WHERE GATE_CD = #{ses.gateCd})
		</if>
            , #{BUYER_CD}
            , #{FORM_ROLE_TYPE}
            , #{DEPT_CD}
            , SYSDATE
            , #{ses.userId}
            , '0'
            , #{USE_FLAG}
        )

         WHEN MATCHED THEN
       UPDATE
          SET BUYER_CD = #{BUYER_CD}
            , FORM_ROLE_TYPE = #{FORM_ROLE_TYPE}
            , DEPT_CD = #{DEPT_CD}
            , USE_FLAG = #{USE_FLAG}
            , MOD_DATE = SYSDATE
            , MOD_USER_ID = #{ses.userId};

     </update>

    <update id="MAUA0050_doDelete" parameterType="hashmap">

        UPDATE STOCECCD
           SET DEL_FLAG = '1'
             , MOD_DATE = SYSDATE
             , MOD_USER_ID = #{ses.userId}
         WHERE GATE_CD = #{ses.gateCd}
           AND ECCD_NUM = #{ECCD_NUM}
           AND DEL_FLAG = '0'

    </update>

</mapper>