    @RequestMapping(value = "/fileAttach/dofileCount")
	public void fileCount(EverHttpRequest req, EverHttpResponse resp) throws Exception {
		Map<String, String> paramMap = new HashMap<String, String>();
        paramMap.put("UUID", req.getParameter("UUID"));
        
		resp.setParameter("FILE_COUNT", String.valueOf(fileAttachService.getFileCount(paramMap.get("UUID"))));
		resp.setResponseMessage("success");
		resp.setResponseCode("true");
	}
    
    //url encode
    public static String fileEnUrl(String inputFile) throws URISyntaxException  {
    	String rtnFileEnurl = "";
        try{
        	URI uri = new URI("file", null, inputFile, null);
        	rtnFileEnurl = uri.toASCIIString();
    	}catch(URISyntaxException ex){
    		System.out.println("URISyntaxException Exception===>"+ex.getMessage());
    	}
    	return rtnFileEnurl;
    }
     
    
    @RequestMapping(value = "/eformPdfMergeAttach")
    public void eformPdfMergeAttach(EverHttpRequest req, EverHttpResponse resp) throws Exception {
        req.setCharacterEncoding("utf-8"); // 주의:한글 파일명의 경우 flex에서 utf-8로 올려보냄 , euc-kr 일경우 선언 필요
                
        String rtnValue = "99";
        
        Map<String, String> param = req.getParamDataMap();
        System.out.println("eformPdfMergeAttach param" + param.toString());

        String SERVERIP = PropertiesManager.getString("epapyrus.IpAddr1");
        Integer SERVERPORT = Integer.parseInt(PropertiesManager.getString("epapyrus.Port1"));        		

        //계약서파일정보
        String tempDirectory = PropertiesManager.getString("oz.source.file.path"); // 파일 임시 저장소         
        String fileName = param.get("fileNm");
        String fileExtension = param.get("fileExtension");
        String tempDirectoryFilePath = tempDirectory + fileExtension + "/" + fileName + "." + fileExtension;
        
        //첨부파일정보
        String bizType = req.getParameter("bizType");        
        String uuid = req.getParameter("uuid");
        
        List<String> inputFiles = new ArrayList<String>();
        inputFiles.add(tempDirectoryFilePath);

        if(EverString.isEmpty(uuid)) {
        } else {
            List<Map<String, Object>> fileInfo = fileAttachService.getFilesInfo(bizType, uuid);
            for (Map<String, Object> file : fileInfo) {

	    		//병합가능 확장자체크   epapyrus.merge.extension.type
	    		String[] extensions = PropertiesManager.getString("epapyrus.merge.extension.type").split(";");
	            for (String extension : extensions) {
	            	if (extension.equalsIgnoreCase(String.valueOf(file.get("FILE_EXTENSION")))) {
	            		inputFiles.add(file.get("FILE_PATH") + "/" + file.get("FILE_NM") + "." + file.get("FILE_EXTENSION"));
	            		System.out.println("eformPdfMergeAttach merge file extension ok ==>" + file.get("FILE_PATH") + "/" + file.get("FILE_NM") + "." + file.get("FILE_EXTENSION"));	            		
	            	}else {
	            		//throw new Exception("계약서에 첨부할 수 있는 첨부파일 종류는 ("+PropertiesManager.getString("epapyrus.merge.extension.type")+") 입니다.");
	            	}
	            }		
            }
        }        
        String outputFile = "//"+tempDirectory + fileExtension + "/" + fileName + "." + fileExtension;
        
        System.out.println("outputFile ====> " + outputFile);
        System.out.println("inputFiles ====> " + inputFiles);
        
    	if (inputFiles == null || inputFiles.size() < 2){
            rtnValue = "99";
    		System.out.println("eformPdfMergeAttach inputFiles.size() : ======> " + inputFiles.size());
    	}else{
    	
            UserInfo userInfo = (UserInfo)req.getSession().getAttribute("ses");
	        List<PdfConversion> convList = new ArrayList<PdfConversion>();
	        List<String> mergeList = new ArrayList<String>();
	        List<String> encryptFileList = new ArrayList<String>();	        
	        boolean isEncryptFile = false;
	    	for (int i = 0; i < inputFiles.size(); i++) {
	            if(DRMUtils.isDRMSupportFile(inputFiles.get(i))) {
	
	                isEncryptFile = DRMUtils.isEncryptedFile(inputFiles.get(i));
	                if (isEncryptFile) {
	                	System.out.println("eformPdfMergeAttach 암호화된 파일입니다. PDF병합을 위해 복호화 합니다. : ======> " + inputFiles.get(i));
	                	if (DRMUtils.decryptFile(inputFiles.get(i), inputFiles.get(i))) {
	                		encryptFileList.add(inputFiles.get(i));
	                		System.out.println("eformPdfMergeAttach 복호화 OK : ======> " + inputFiles.get(i));
	                    }
	                }
	            }		
	    		convList.add(PdfConversion.create(fileEnUrl("//"+inputFiles.get(i))));
	    		mergeList.add(new String("all"));
	    	}
	
	    	String pid = EverDate.getTimeStampString();

	    	PdfGatewayAgent.of(SERVERIP, SERVERPORT)
	                .name("mergePDF")    
	                .externalId(pid)
	                .conversion(convList)
	                .merge(mergeList)
	                .distribute(fileEnUrl(outputFile))
	                .start();
	    	
	        while(!PdfGatewayAgent.of(SERVERIP, SERVERPORT).taskStatus(PdfGateway.IdType.EXTERNAL, pid).name().equals("SUCCESS")){
	        	try{
	            	Thread.sleep(1000);
	            	System.out.println("eformPdfMergeAttach PdfGatewayAgent waiting===>"+PdfGatewayAgent.of(SERVERIP, SERVERPORT).taskStatus(PdfGateway.IdType.EXTERNAL, pid).name());
	            	if(PdfGatewayAgent.of(SERVERIP, SERVERPORT).taskStatus(PdfGateway.IdType.EXTERNAL, pid).name().equals("FAILURE") || PdfGatewayAgent.of(SERVERIP, SERVERPORT).taskStatus(PdfGateway.IdType.EXTERNAL, pid).name().equals("CANCELLED")) {
		                rtnValue = rtnValue + ",88";
		        		System.out.println("eformPdfMergeAttach PdfGatewayAgent RETURN FAILURE!");
	            		break;
	            	}
	        	}catch(InterruptedException ex){
	        		rtnValue = rtnValue + ",77";
	                System.out.println("eformPdfMergeAttach PdfGatewayAgent PROCESS FAILURE!");	            		
            		break;
	        	}
	        }    
	        
	    	for (int i = 0; i < encryptFileList.size(); i++) {
	            if(DRMUtils.isDRMSupportFile(encryptFileList.get(i))) {
	
	                isEncryptFile = DRMUtils.isEncryptedFile(encryptFileList.get(i));
	                if (!isEncryptFile) {
	                	System.out.println("eformPdfMergeAttach PDF병합을 위해 복호화한 파일 암호화 처리 : ======> " + encryptFileList.get(i));
	                    userInfo.setUserId("00000000");
	                    userInfo.setUserNm("운영사");
	                    userInfo.setDeptCd("000000");
	                    userInfo.setDeptNm("전자구매시스템");	                    
	                	if (DRMUtils.encryptFile(encryptFileList.get(i), encryptFileList.get(i), encryptFileList.get(i), userInfo)) {	
	                		System.out.println("eformPdfMergeAttach 암호화 OK : ======> " + encryptFileList.get(i));
	                    }
	                }
	            }		
	    	}	        
        
    	}

        HashMap<String, String> returnInfo = new HashMap<String, String>();
        returnInfo.put("rtnValue", rtnValue);
        resp.sendJSON(returnInfo);     
        
    }   
    
