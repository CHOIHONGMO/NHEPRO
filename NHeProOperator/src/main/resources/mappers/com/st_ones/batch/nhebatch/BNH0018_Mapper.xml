<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.batch.nhebatch.BNH0018_Mapper">
	
 	<!-- 11개월 장기 미사용자 메일 발송 -->
      <select id="getTargetData" resultType="hashmap" parameterType="hashMap">
		SELECT USER_ID
			 , <include refid="common.sql.strDecStart"/>USER_NM<include refid="common.sql.strDecEnd"/> AS USER_NM
			 , <include refid="common.sql.strDecStart"/>CELL_NUM<include refid="common.sql.strDecEnd"/> AS CELL_NUM
		  FROM STOCTVUR
		 WHERE GATE_CD  = #{ses.gateCd}
		 AND TO_CHAR(LAST_LOGIN_DATE, 'YYYYMMDD') = TO_CHAR(ADD_MONTHS(SYSDATE, -11), 'YYYYMMDD')
	</select>

</mapper>
