<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.eversrm.eApproval.eApprovalEnd.BID.EApprovalEndBid_Mapper">

    <select id="getBidNum" parameterType="hashMap" resultType="hashMap">

        SELECT
             BID_NUM, BID_CNT
            ,BID_CNT - 1 AS PRE_BID_CNT
          FROM STOCBDHD
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND APP_DOC_NUM = #{APP_DOC_NUM}
           AND APP_DOC_CNT = #{APP_DOC_CNT}
           AND DEL_FLAG = '0'

    </select>

    <update id="setBidSignStatus" parameterType="hashmap">

        UPDATE STOCBDHD SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
            ,SIGN_STATUS = #{SIGN_STATUS}
        <if test='SIGN_STATUS == "E" or SIGN_STATUS == "R"'>
            ,SIGN_DATE = SYSDATE
        </if>
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND BID_NUM = #{BID_NUM}
           AND BID_CNT = #{BID_CNT}

    </update>

    <update id="setBidStatus" parameterType="hashmap">

		UPDATE STOCBDHD SET
			BID_STATUS = #{BID_STATUS}
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND BID_NUM = #{BID_NUM}
           AND BID_CNT = #{BID_CNT}

    </update>
	
	<!-- 입찰공고시 사용수수료 청구 -->
    <select id="getPrepaymentData" parameterType="hashmap" resultType="hashmap">

        SELECT
              CUST.IRS_NUM 		AS CORP_NO
            , HD.DEPT_CD 		AS BRC
            , HD.ANN_DATE 		AS APLY_DT
            , HD.REG_USER_ID 	AS USER_ID
            , 'BID'       <include refid="common.sql.stringMerge"/> '@@' <include refid="common.sql.stringMerge"/>
              HD.GATE_CD  <include refid="common.sql.stringMerge"/> '@@' <include refid="common.sql.stringMerge"/>
              HD.BUYER_CD <include refid="common.sql.stringMerge"/> '@@' <include refid="common.sql.stringMerge"/>
              HD.BID_NUM  <include refid="common.sql.stringMerge"/> '@@' <include refid="common.sql.stringMerge"/>
              HD.BID_CNT 		AS CONT_TBL_PK
            , NULL 				AS FILE_SIZE
          FROM STOCBDHD HD
          LEFT JOIN STOCCUST CUST
	           ON (HD.GATE_CD  = CUST.GATE_CD
	           AND HD.BUYER_CD = CUST.CUST_CD)
          LEFT JOIN STOCCVUR CVUR
	           ON (HD.GATE_CD     = CVUR.GATE_CD
	           AND HD.REG_USER_ID = CVUR.USER_ID)
         WHERE HD.GATE_CD  = #{ses.gateCd}
           AND HD.BUYER_CD = #{BUYER_CD}
           AND HD.BID_NUM  = #{BID_NUM}
           AND HD.BID_CNT  = #{BID_CNT}
    </select>

    <select id="getRltBidNum" parameterType="hashMap" resultType="hashMap">

        SELECT
            BID_NUM, BID_CNT
          FROM STOCBDHD
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND RLT_APP_DOC_NUM = #{APP_DOC_NUM}
           AND RLT_APP_DOC_CNT = #{APP_DOC_CNT}
           AND DEL_FLAG = '0'

    </select>

    <update id="setRltSignStatus" parameterType="hashmap">

        UPDATE STOCBDHD SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
            ,RLT_SIGN_STATUS = #{SIGN_STATUS}
        <if test='SIGN_STATUS == "E" or SIGN_STATUS == "R"'>
            ,RLT_SIGN_DATE = SYSDATE
        </if>
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND BID_NUM = #{BID_NUM}
           AND BID_CNT = #{BID_CNT}

    </update>

    <select id="getNegoBidNum" parameterType="hashMap" resultType="hashMap">

        SELECT
            BID_NUM, BID_CNT
          FROM STOCBDHD
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND NEGO_APP_DOC_NUM = #{APP_DOC_NUM}
           AND NEGO_APP_DOC_CNT = #{APP_DOC_CNT}
           AND DEL_FLAG = '0'

    </select>

    <update id="setNegoSignStatus" parameterType="hashmap">

        UPDATE STOCBDHD SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
        <if test='SIGN_STATUS == "E"'>
            ,BID_STATUS = '2410'
        </if>
            ,NEGO_SIGN_STATUS = #{SIGN_STATUS}
        <if test='SIGN_STATUS == "E" or SIGN_STATUS == "R"'>
            ,NEGO_SIGN_DATE = SYSDATE
        </if>
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND BID_NUM = #{BID_NUM}
           AND BID_CNT = #{BID_CNT}

    </update>

    <select id="getMailTargetList" parameterType="hashmap" resultType="hashmap">

        SELECT
              HD.ANN_ITEM
             ,AP.VENDOR_CD AS RECV_USER_ID
             ,<include refid="common.sql.dbo"/>GETUSERNAME(AP.GATE_CD, AP.REG_USER_ID, #{ses.langCd}) AS RECV_USER_NM
             ,VNGL.VENDOR_NM
             ,<include refid="common.sql.dbo"/>GETCOMPANYNAME(HD.GATE_CD, (SELECT MAX(DT.PR_BUYER_CD) FROM STOCBDDT DT
                                           WHERE DT.GATE_CD = HD.GATE_CD
                                             AND DT.BUYER_CD = HD.BUYER_CD
                                             AND DT.BID_NUM = HD.BID_NUM
                                             AND DT.BID_CNT = HD.BID_CNT
                                             AND DT.DEL_FLAG = '0'), #{ses.langCd}) AS PR_BUYER_NM
             ,TO_CHAR(TO_DATE(HD.ANN_DATE, 'YYYYMMDD'), 'YYYY-MM-DD') AS ANN_FROM_DATE
             ,(CASE WHEN TO_DATE(HD.APP_BEGIN_DATE, 'YYYYMMDD') - 1 <![CDATA[<]]> TO_DATE(HD.ANN_DATE, 'YYYYMMDD')
                    THEN TO_CHAR(TO_DATE(HD.ANN_DATE, 'YYYYMMDD'), 'YYYY-MM-DD')
                    ELSE TO_CHAR(TO_DATE(HD.APP_BEGIN_DATE, 'YYYYMMDD') - 1, 'YYYY-MM-DD') END) AS ANN_TO_DATE
             ,TO_CHAR(TO_DATE(HD.APP_END_DATE, 'YYYYMMDD'), 'YYYY-MM-DD') AS APP_END_DATE
             ,<include refid="common.sql.dbo"/>GETCOMCODE(HD.GATE_CD, 'M301', HD.CONT_TYPE1, 0, #{ses.langCd}) AS CONT_TYPE1_LOC
             ,<include refid="common.sql.dbo"/>GETCOMCODE(HD.GATE_CD, 'M302', HD.CONT_TYPE2, 0, #{ses.langCd}) AS CONT_TYPE2_LOC
          FROM STOCBDHD HD INNER JOIN STOCBDAP AP
           ON (HD.GATE_CD = AP.GATE_CD
           AND HD.BUYER_CD = AP.BUYER_CD
           AND HD.BID_NUM = AP.BID_NUM
           AND HD.BID_CNT = AP.BID_CNT)
          LEFT JOIN STOCVNGL VNGL
           ON (AP.GATE_CD = VNGL.GATE_CD
           AND AP.VENDOR_CD = VNGL.VENDOR_CD)
         WHERE HD.GATE_CD = #{ses.gateCd}
           AND HD.BUYER_CD = #{BUYER_CD}
           AND HD.BID_NUM = #{BID_NUM}
           AND HD.BID_CNT = #{BID_CNT}

    </select>

</mapper>