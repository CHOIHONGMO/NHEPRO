<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.st_ones.eversrm.master.user.MTUB0010_Mapper">
	
	<resultMap id="clobMap" type="HashMap">
		<result property="JOB_CONTENTS" column="JOB_CONTENTS" jdbcType="CLOB" javaType="java.lang.String" />
	</resultMap>
	
    <select id="mtub0010_doSearch" parameterType="hashMap" resultMap="clobMap">

        SELECT A.*
             ,<include refid="common.sql.nvl"/>(A.SCREEN_URL,A.SCREEN_NMS) AS SCREEN_NM
             ,<include refid="common.sql.nvl"/>(A.STATUS1, A.STATUS2) AS STATUS
          FROM (SELECT
          			  BUYER_CD
                    ,<include refid="common.sql.toChar"/>(ULOG.JOB_DATE, 'YYYY-MM-DD HH24:mi:ss') AS JOB_DATE
                    , ULOG.JOB_DATE AS JOBDATE
                    , ULOG.JOB_TYPE
                    , ULOG.FAIL_TYPE
                    , ULOG.JOB_DESC
                    , SUBSTR(ULOG.JOB_CONTENTS, 0, 4000) AS JOB_CONTENTS
                    , ULOG.MODULE_NM
                    , ULOG.METHOD_NM AS METHOD_NM
                    ,(CASE WHEN ULOG.USER_TYPE = 'N' THEN '' ELSE ULOG.USER_TYPE END) AS USER_TYPE
                    , ULOG.TMPL_MENU_CD
                    , ULOG.USER_ID
                    ,<include refid="common.sql.dbo"/>GETCOMCODE(#{ses.gateCd}, 'MP014', ULOG.USER_STATUS, '0', #{ses.langCd}) AS STATUS1
                    ,(SELECT <include refid="common.sql.dbo"/>GETCOMCODE(#{ses.gateCd}, 'MP014', USR.STATUS, '0', #{ses.langCd})
                        FROM STOCUSER USR
                       WHERE USR.GATE_CD = ULOG.GATE_CD AND USR.USER_ID = ULOG.USER_ID AND USR.DEL_FLAG = '0') AS STATUS2
                    ,(CASE WHEN ULOG.USER_TYPE = 'O'
                           THEN
                              (SELECT <include refid="common.sql.strDecStart"/>U.USER_NM<include refid="common.sql.strDecEnd"/> <include refid="common.sql.stringMerge"/>  ' / '    <include refid="common.sql.stringMerge"/>	GETCOMPANYNAME(U.GATE_CD,U.COMPANY_CD,'KO')  <include refid="common.sql.stringMerge"/> ' / ' <include refid="common.sql.stringMerge"/> <include refid="common.sql.nvl"/>( <include refid="common.sql.dbo"/>GETDEPTNAME(U.GATE_CD, U.COMPANY_CD, U.DEPT_CD, #{ses.langCd}), '')
                                 FROM STOCUSER U
                                WHERE U.GATE_CD = ULOG.GATE_CD
                                  AND U.USER_ID = ULOG.USER_ID)
                           ELSE
                              (SELECT <include refid="common.sql.strDecStart"/>U.USER_NM<include refid="common.sql.strDecEnd"/> <include refid="common.sql.stringMerge"/> ' / '    <include refid="common.sql.stringMerge"/>	GETCOMPANYNAME(U.GATE_CD,U.COMPANY_CD,'KO')  <include refid="common.sql.stringMerge"/>  ' / ' <include refid="common.sql.stringMerge"/> <include refid="common.sql.nvl"/>(U.DEPT_NM,'')
                                 FROM STOCCVUR U
                                WHERE U.GATE_CD = ULOG.GATE_CD
                                  AND U.USER_ID = ULOG.USER_ID)
                           END) AS USER_NM
                    , ULOG.IP_ADDR
                    , ULOG.SCREEN_ID AS SCREEN_ID
                    ,(CASE WHEN ULOG.SCREEN_ID IS NOT NULL
                           THEN
                              (SELECT MAX(M.MULTI_NM)
                                 FROM STOCMULG M
                                WHERE M.GATE_CD   = ULOG.GATE_CD
                                  AND M.DEL_FLAG  = '0'
                                  AND M.MULTI_CD  = 'SC'
                                  AND M.LANG_CD   = #{ses.langCd}
                                  AND M.SCREEN_ID = ULOG.SCREEN_ID)
                           ELSE
                              (SELECT MAX(M.MULTI_NM)
                                 FROM STOCMULG M
                                WHERE M.GATE_CD   = ULOG.GATE_CD
                                  AND M.DEL_FLAG  = '0'
                                  AND M.MULTI_CD  = 'MT'
                                  AND M.LANG_CD   = #{ses.langCd}
                                  AND M.SCREEN_ID = ULOG.TMPL_MENU_CD)
                           END) AS SCREEN_NMS
                    ,(SELECT MAX( <include refid="common.sql.dbo"/>GETCOMCODE(MUTG.GATE_CD, 'M009', MUTG.MODULE_TYPE, '0', #{ses.langCd})
                                <include refid="common.sql.stringMerge"/>'<![CDATA[>]]>'
                                <include refid="common.sql.stringMerge"/> <include refid="common.sql.dbo"/>GETMULTINAME(MUTM.GATE_CD, 'MT', #{ses.langCd},
                                                                      (SELECT TM.TMPL_MENU_CD
                                                                         FROM STOCMUTM TM
                                                                        WHERE TM.GATE_CD = MUTM.GATE_CD
                                                                          AND TM.TMPL_MENU_CD = (
                                                                                CASE WHEN (MUTM.HIGH_TMPL_MENU_CD = '' OR MUTM.HIGH_TMPL_MENU_CD IS NULL)
                                                                                     THEN ''
                                                                                     ELSE MUTM.HIGH_TMPL_MENU_CD
                                                                                END)
                                                                      ),
                                                                      <include refid="common.sql.nvl"/>(null, '-')
                                )  -- GETMULTINAME
                                <include refid="common.sql.stringMerge"/> '<![CDATA[>]]>'
                                <include refid="common.sql.stringMerge"/> <include refid="common.sql.dbo"/>GETMULTINAME(MUTM.GATE_CD, 'MT', #{ses.langCd}
                                                                       ,MUTM.TMPL_MENU_CD
                                                                       ,CASE WHEN MUTM.SCREEN_ID IS NULL OR MUTM.SCREEN_ID = ''
                                                                             THEN '-'
                                                                             ELSE MUTM.SCREEN_ID
                                                                        END)
                            ) -- MAX
                        FROM STOCMUTM MUTM
                        JOIN STOCMUTG MUTG
                         ON (MUTM.GATE_CD = MUTG.GATE_CD
                         AND MUTM.TMPL_MENU_GROUP_CD = MUTG.TMPL_MENU_GROUP_CD)
                       WHERE MUTM.GATE_CD = ULOG.GATE_CD
                         AND MUTM.SCREEN_ID = ULOG.SCREEN_ID) AS SCREEN_URL
                    ,<include refid="common.sql.nvl"/>(ULOG.ACTION_CD, 'Screen') AS ACTION_CD
                    ,CASE WHEN <include refid="common.sql.nvl"/>(ULOG.ACTION_CD,'Screen') = 'Screen' THEN <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd}, 'MP015', 'Screen', #{ses.langCd})
                          WHEN ULOG.ACTION_CD = 'Logout' THEN  <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd}, 'MP015', 'Logout', #{ses.langCd})
                          WHEN ULOG.ACTION_CD = 'Login' THEN  <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd}, 'MP015', 'Login', #{ses.langCd})
                          WHEN ULOG.ACTION_CD = 'ExcelDownload' THEN  <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd}, 'MP015', 'ExcelDownload', #{ses.langCd})
                          WHEN ULOG.ACTION_CD = 'menuClick' THEN  <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd}, 'MP015', 'Screen', #{ses.langCd})
                          ELSE (SELECT MAX(M.MULTI_NM)
                                  FROM STOCMULG M
                                 WHERE M.GATE_CD = ULOG.GATE_CD
                                   AND M.DEL_FLAG = '0'
                                   AND M.MULTI_CD = 'SA'
                                   AND M.LANG_CD = #{ses.langCd}
                                   AND M.SCREEN_ID = ULOG.SCREEN_ID
                                   AND M.ACTION_CD = ULOG.ACTION_CD)
                          END AS ACTION_NM
                    , ULOG.GATE_CD
                 FROM STOCULOG ULOG
                WHERE ULOG.GATE_CD = #{ses.gateCd}
        <if test="BUYER_CD != '' and BUYER_CD != null">
            AND ULOG.BUYER_CD = #{BUYER_CD}
        </if>
          ) A
        WHERE 1 = 1
        <if test="ADD_DATE_FROM != '' and ADD_DATE_FROM != null and ADD_DATE_TO != '' and ADD_DATE_TO != null">
            AND A.JOBDATE <![CDATA[>=]]> <include refid="common.sql.toDateFrom"/>(#{ADD_DATE_FROM})
	        AND A.JOBDATE <![CDATA[<=]]> <include refid="common.sql.toDateTo"/>(#{ADD_DATE_TO})
        </if>
        <if test="JOB_TYPE != '' and JOB_TYPE != null">
			AND A.JOB_TYPE IN ${JOB_TYPE}
		</if>
        <if test="FAIL_TYPE != '' and FAIL_TYPE != null">
            AND A.FAIL_TYPE = #{FAIL_TYPE}
        </if>
        <if test="USER_TYPE != '' and USER_TYPE != null">
            AND A.USER_TYPE = #{USER_TYPE}
        </if>
        <if test="USER_ID != '' and USER_ID != null">
	        AND UPPER(A.USER_ID) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{USER_ID}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="SEARCH_TYPE != '' and SEARCH_TYPE != null">
            <if test="SEARCH_TYPE == 'MENU'">
                AND A.TMPL_MENU_CD IS NOT NULL
            </if>
            <if test="SEARCH_TYPE == 'SCREEN'">
                AND A.SCREEN_ID IS NOT NULL
            </if>
        </if>
        <if test="USER_NM != '' and USER_NM != null">
	         AND UPPER(USER_NM) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{USER_NM}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="IP_ADDR != '' and IP_ADDR != null">
	         AND UPPER(A.IP_ADDR) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{IP_ADDR}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="METHOD_NM != '' and METHOD_NM != null">
	         AND UPPER(A.METHOD_NM) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{METHOD_NM}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="MODULE_NM != '' and MODULE_NM != null">
	         AND UPPER(A.MODULE_NM) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{MODULE_NM}) <include refid="common.sql.stringMerge"/> '%'
		</if>
        <if test="OB_DESC != '' and JOB_DESC != null">
	         AND UPPER(A.JOB_DESC) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{JOB_DESC}) <include refid="common.sql.stringMerge"/> '%'
		</if>
        <if test="SCREEN_ID != '' and SCREEN_ID != null">
            AND <include refid="common.sql.nvl"/>(A.SCREEN_ID, ' ') <include refid="common.sql.stringMerge"/> <include refid="common.sql.nvl"/>(A.TMPL_MENU_CD, ' ') LIKE '%' <include refid="common.sql.stringMerge"/> #{SCREEN_ID} <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="ACTION_CD != '' and ACTION_CD != null">
            AND
            <include refid="common.sql.nvl"/>(<include refid="common.sql.dbo"/>GETMULTINAME(A.GATE_CD, 'SC', #{ses.langCd}, '', A.SCREEN_ID), ' ')
            <include refid="common.sql.stringMerge"/>
            <include refid="common.sql.nvl"/>(<include refid="common.sql.dbo"/>GETMULTINAME(A.GATE_CD, 'MT', #{ses.langCd}, '', A.TMPL_MENU_CD), ' ')
			LIKE '%'<include refid="common.sql.stringMerge"/>#{ACTION_CD}<include refid="common.sql.stringMerge"/>'%'
        </if>
    </select>
    
</mapper>
