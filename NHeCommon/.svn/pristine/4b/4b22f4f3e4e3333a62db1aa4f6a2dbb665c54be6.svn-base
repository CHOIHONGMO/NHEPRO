	/**
	 * 로그인 체크
	 * @param req
	 * @param resp
	 * @throws Exception
	 */
	@RequestMapping(value = "/login")
	public void login(EverHttpRequest req, EverHttpResponse resp) throws Exception {
		LoginSearch loginSearch = new LoginSearch();

		/*
		 * String privateKey = PropertiesManager.getString("touchEnNx.key.path");
		 * E2ECrypto Tk = null;
		 * 
		 * if (Tk == null) { Tk = new E2ECrypto(req.getSession());
		 * Tk.E2E_KeyExchange(req.getParameter("hid_key_data"), privateKey);
		 * 
		 * int LastError = Tk.getLastError(); if (LastError != 0) { throw new
		 * Exception("TouchEnKey decode ERROR."); } }
		 */

		//String EuserId = Tk.decryptE2EField(req.getParameter("userId"));
		//String EuserPw = Tk.decryptE2EField(req.getParameter("password"));
		String EuserId = req.getParameter("userId");
		String EuserPw = req.getParameter("password");
		String ipAddress = EverString.getClientIP();

		HttpSession session = req.getSession(true);
	    java.security.PrivateKey privateKey = (java.security.PrivateKey) session.getAttribute(RSA_WEB_KEY);
		logger.debug("RSA 확인 ! req.getParameter(\"incryptFlag\") : " + req.getParameter("incryptFlag"));
		// 복호화
        if(!"Y".equals(req.getParameter("incryptFlag"))) {
            EuserId = decryptRsa(privateKey, EuserId);
            EuserPw = decryptRsa(privateKey, EuserPw);
            logger.debug("RSA 확인 ! EuserId : " + EuserId);
            logger.debug("RSA 확인 ! EuserPw : " + EuserPw);
        }

		final String userId = EuserId.trim().toUpperCase();
		Map<String, String> param = new HashMap<String, String>();
		param.put("GATE_CD", PropertiesManager.getString("eversrm.gateCd.default"));
		param.put("USER_ID", userId);

		loginSearch.setUserId(userId);
		loginSearch.setPassword(EverEncryption.getEncryptedUserPassword(EverString.nullToEmptyString(EuserPw)));
		loginSearch.setCheckUserMonth(EverString.nullToEmptyString(req.getParameter("checkUserMonth")));
		loginSearch.setSiteType(req.getParameter("siteType"));

		if (EverString.nullToEmptyString(req.getParameter("sessionChange")).length() == 0) {
			loginSearch.setSessionChange("false");
		} else {
			loginSearch.setSessionChange(req.getParameter("sessionChange"));
			loginSearch.setUserType(req.getParameter("userType"));
		}
		loginSearch.setGateCd(PropertiesManager.getString("eversrm.gateCd.default"));

		Map<String, UserInfo> resultInfo = new HashMap<String, UserInfo>();
		LoginResultType loginResultType = null;
		if(loginSearch != null) {
			loginResultType = loginService.login(loginSearch, resultInfo);
		}

		//사용자타입
		String userType = "";
		if(resultInfo.get("baseInfo") != null) {
			userType = resultInfo.get("baseInfo").getUserType();
		}

		// 운영사 시스템 사용자는 3 개의 IP 를 등록하고 해당 IP 로만 로그인이 되도록 처리 ( 공통코드 적용 )
		/*
		if(resultInfo.get("baseInfo") != null && userType.equals("O")) {
			if (!PropertiesManager.getBoolean("eversrm.system.localserver") && !PropertiesManager.getBoolean("eversrm.system.developmentFlag")) {

				Map<String, String> sParam = new HashMap<String, String>();
				sParam.put("GATE_CD", PropertiesManager.getString("eversrm.gateCd.default"));
				sParam.put("CODE_TYPE", "NH0038");

				List<Map<String, String>> ipList = loginService.getPossibleIP(sParam);
				if (ipList.size() > 0) {
					boolean possibleFlag = false;
					for(Map<String, String> ipData : ipList) {
						if(ipData.get("IPS").equals(ipAddress)) {
							possibleFlag = true;
						}
					}
					if(!possibleFlag) {
						loginResultType = LoginResultType.IMPOSSIBLE_IP;
					}
				} else {
					loginResultType = LoginResultType.NOT_EXIST_IP_INFO;
				}
			}
		}
		*/

		// 미승인 사용자 로그인시...
		if(resultInfo.get("baseInfo") != null) {
			if(!resultInfo.get("baseInfo").getProgressCd().equals("E")) {
				loginResultType = LoginResultType.NOT_APPROVAL;
			}
		}

		// Block 사용자 로그인시...
		if(resultInfo.get("baseInfo") != null) {
			if (resultInfo.get("baseInfo").getBlockFlag().equals("1")) {
				loginResultType = LoginResultType.NOT_APPROVAL;
			}
		}

		// 비밀번호 오류
		if (loginResultType == LoginResultType.FAIL_WRONG_PASSWORD) {
			utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "잘못된 비밀번호 입력", "F", userId, req.getRemoteAddr(), "", userType);
			loginService.updateWrongPasswordCount(param);
		}
		else if(loginResultType == LoginResultType.SUCCESS) {
			loginService.resetPasswordWrongCount(param);

            /*// 최종 로그인 90일 접근 제한(통제)
            int dayCount = loginService.get90DaysCount(param);
            if(dayCount == 0) {
                utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "로그인 90일 경과 실패", "F", userId, ipAddress, "", "P");
                loginResultType = LoginResultType.FAIL_LOGIN_DATE_PASS;
            }*/

            // PW_RESET_FLAG 체크
            int pwResetFlag = loginService.getPwResetFlag(param);
            if(pwResetFlag == 1) {
                utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "패스워드 임시발급 후 재설정", "F", userId, ipAddress, "", "P");
                loginResultType = LoginResultType.WRONG_PASSWORD_RESET_FLAG;
            }

            // 비밀번호 변경일 90일 경과 체크
            int pwResetDateFlag = loginService.getPwResetDate(param);
            if(pwResetDateFlag == 0) {
                utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "패스워드 변경일자 180일 경과", "F", userId, ipAddress, "", "P");
                loginResultType = LoginResultType.WRONG_PASSWORD_RESET_DATE;
            }
		}

		boolean PasswordFailCountFlag = PropertiesManager.getBoolean("everF.login.PasswordFailCountFlag");
		int passwordWrongCount = 0;
		if (PasswordFailCountFlag) {
			int WrongLimit = Integer.parseInt(PropertiesManager.getString("everF.login.WrongLimit"));
			passwordWrongCount = loginService.getPasswordWrongCount(param);
			if(passwordWrongCount >= WrongLimit) {
				utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "비밀번호 " + passwordWrongCount + "회 실패", "F", userId, req.getRemoteAddr(), "F", userType);
				loginResultType = LoginResultType.WRONG_PASSWORD_EXCEEDED_CNT;
			}
		}

		processCommonLogin(req, resp, loginResultType, resultInfo, passwordWrongCount, false);
	}

	private void processCommonLogin(EverHttpRequest req, EverHttpResponse resp, LoginResultType loginResultType, Map<String, UserInfo> resultInfo, int passwordWrongCount, boolean isSsoLogin) throws Exception {

		ObjectMapper mapper = new ObjectMapper();
		// 성공
		if (loginResultType == LoginResultType.SUCCESS || loginResultType == LoginResultType.WRONG_PASSWORD_RESET_DATE) {
			// 동일한 아이피가 아닌 경우 로그아웃
			loginService.checkLoggedUserExists(req, resp, resultInfo);
			if(resp.getResponseCode().equals("200")) {

				getLog().info("Creating User Session");
				createLoginUserSession(req, resp, resultInfo);
				resp.setParameter("redirectUrl", "/welcome.so");

				Map<String, String> userInfo = new HashMap<String, String>();
				UserInfo baseInfo = resultInfo.get("baseInfo");
				userInfo.put("GATE_CD", baseInfo.getGateCd());
				userInfo.put("USER_ID", baseInfo.getUserId());
				userInfo.put("LANG_CD", baseInfo.getLangCd());

				//중복세션 체크
				Boolean userSessionChk = userSession(req, resp, resultInfo, userInfo);
				if(userSessionChk) {
					resp.setResponseMessage("이미 로그인 된 사용자 입니다. 접속하실 수 없습니다.");
				} else {
					//로그인일시 업데이트
					loginService.setLastLoginDate(userInfo, req);
				}
				// 개인키 삭제
				// HttpSession session = req.getSession();
				// session.removeAttribute(RSA_WEB_KEY);
			}
			if (loginResultType == LoginResultType.WRONG_PASSWORD_RESET_DATE) {
				resp.setResponseCode("180");
				resp.setResponseMessage("비밀번호 변경일이 180일 초과 하였습니다.\n비밀번호를 변경하시기 바랍니다.");
			}
			if (req.getParameter("sessionChange") != null && Boolean.valueOf(req.getParameter("sessionChange"))) {
				// return "forward:/home.so";
				req.getRequestDispatcher("/home.so").forward(req, resp);
			}
		}
		// 아이디 미존재
		else if (loginResultType == LoginResultType.FAIL_NOT_EXIST_ID) {
			resp.setResponseMessage("로그인 아이디가 올바르지 않습니다.");
		}
		// 비밀번호 실패시
		else if (loginResultType == LoginResultType.FAIL_WRONG_PASSWORD) {
			resp.setResponseMessage("로그인 비밀번호가 올바르지 않습니다.");
		}
		// User Type 미존재
		else if (loginResultType == LoginResultType.FAIL_NOT_EXIST_USER_TYPE) {
			resp.setResponseMessage("사용자 유형이 올바르지 않습니다. 고객센터에 문의하세요.");
		}
		// 운영사 접근가능 IP 정보 미존재
		else if (loginResultType == LoginResultType.NOT_EXIST_IP_INFO) {
			resp.setResponseMessage("운영사 접근가능 IP 정보가 존재하지 않습니다.");
		}
		// 운영사 접근가능 IP가 아님.
		else if (loginResultType == LoginResultType.IMPOSSIBLE_IP) {
			resp.setResponseMessage("접근가능한 IP가 아닙니다.");
		}

		// 비밀번호 "everF.login.WrongLimit" 이상 잘못 입력시
		else if (loginResultType == LoginResultType.WRONG_PASSWORD_EXCEEDED_CNT) {
			resp.setResponseMessage("비밀번호를 " + passwordWrongCount + "회 잘못 입력하여 로그인이 금지되었습니다.\n비밀번호를 변경하고 다시 로그인해주시기 바랍니다.");
		}
		// 최종로그인 일시가 3개월이 지나면
		/*else if (loginResultType == LoginResultType.FAIL_LOGIN_DATE_PASS) {
			UserInfo baseInfo = resultInfo.get("baseInfo");
			resp.setParameter("redirectUrl", "/welcomeSupplier.so");
			resp.setParameter("IrsNum", baseInfo.getIrsNum());
			resp.setResponseMessage("최종로그인이 3개월 이상 지났습니다.\n" +"\n" +"공인인증으로 사용승인 후 다시 로그인하세요.\n" +"공인인증으로 사용자 인증을 받으시려면 확인을 누르세요.");
		}
        // 비밀번호 180일 변경일 체크
        else if (loginResultType == LoginResultType.WRONG_PASSWORD_RESET_DATE) {
            resp.setResponseMessage("비밀번호 변경일이 180일 초과 하였습니다.\n비밀번호를 변경하시기 바랍니다.");
        }*/
        else if (loginResultType == LoginResultType.WRONG_PASSWORD_RESET_FLAG) {
			resp.setResponseMessage("비밀번호가 초기화 되었습니다.\n비밀번호를 변경하시기 바랍니다.");
		}
        else if (loginResultType == LoginResultType.LONG_TERM_NON_USER) {
        	resp.setResponseCode("nonUser");
        	resp.setResponseMessage("휴먼계정으로 전환된 사용자 입니다.\n휴먼계정을 해지하시겠습니까?");
		}
        else if (loginResultType == LoginResultType.NOT_APPROVAL) {
			resp.setResponseMessage("승인되지 않은 사용자 입니다. 관리자에게 문의 바랍니다.");
		}
		else {
			resp.setResponseMessage("아이디 또는 비밀번호를 확인하세요.\n관리자 또는 고객센터로 문의 바랍니다.");
			//resp.getWriter().write(mapper.writeValueAsString(resp.getParameterMap()).toString());
		}
	}

	/**
	 * 모바일 로그인 체크
	 * @param req
	 * @param resp
	 * @throws Exception
	 */
	@RequestMapping(value = "/mobileLogin")
	public void mobileLogin(EverHttpRequest req, EverHttpResponse resp) throws Exception {

		final String userId = req.getParameter("userId").trim().toUpperCase();
		String ppdd = EverString.nullToEmptyString(req.getParameter("password"));
		String shaPpdd = EverEncryption.getEncryptedUserPassword(ppdd);
		String ipAddress = EverString.getClientIP();

		Map<String, String> param = new HashMap<String, String>();
		param.put("GATE_CD", PropertiesManager.getString("eversrm.gateCd.default"));
		param.put("USER_ID", userId);

		LoginSearch loginSearch = new LoginSearch();
		loginSearch.setUserId(userId);
		loginSearch.setIpAddress(ipAddress);
		loginSearch.setPassword(shaPpdd);

		loginSearch.setGateCd(PropertiesManager.getString("eversrm.gateCd.default"));
		Map<String, UserInfo> resultInfo = new HashMap<String, UserInfo>();

		LoginResultType loginResultType = loginService.mobileLogin(loginSearch, resultInfo);

		boolean PasswordFailCountFlag = PropertiesManager.getBoolean("everF.login.PasswordFailCountFlag");
		int passwordWrongCount = 0;
		if (PasswordFailCountFlag) {
			int WrongLimit = Integer.parseInt(PropertiesManager.getString("everF.login.WrongLimit"));
			passwordWrongCount = loginService.getPasswordWrongCount(param);
			if(passwordWrongCount >= WrongLimit) {
				utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "mobileHome", "Login", "비밀번호 " + passwordWrongCount + "회 실패", "F", userId, ipAddress, "", "P");
				loginResultType = LoginResultType.WRONG_PASSWORD_EXCEEDED_CNT;
			}
		}
		else if (loginResultType == LoginResultType.FAIL_WRONG_PASSWORD) {
			param.put("USER_ID", resultInfo.get("baseInfo").getUserId());
			loginService.updateWrongPasswordCount(param);
		}
		else if (loginResultType == LoginResultType.NOT_USE_FLAG) {
			param.put("USER_ID", resultInfo.get("baseInfo").getUserId());
		}
		else if (loginResultType == LoginResultType.NOT_APPROVAL) {
			param.put("USER_ID", resultInfo.get("baseInfo").getUserId());
		}
		else if(loginResultType == LoginResultType.SUCCESS) {
			param.put("USER_ID", resultInfo.get("baseInfo").getUserId());
			loginService.resetPasswordWrongCount(param);

			// 최종 로그인 90일 접근 제한(통제)
			/*int dayCount = loginService.get90DaysCount(param);
			if(dayCount == 0) {
				utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "로그인 90일 경과 실패", "F", userId, ipAddress, "", "P");
				loginResultType = LoginResultType.FAIL_LOGIN_DATE_PASS;
			}*/

			// PW_RESET_FLAG 체크
			int pwResetFlag = loginService.getPwResetFlag(param);
			if(pwResetFlag == 1) {
				utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "패스워드 임시발급 후 재설정", "F", userId, ipAddress, "", "P");
				loginResultType = LoginResultType.WRONG_PASSWORD_RESET_FLAG;
			}

			// 비밀번호 변경일 180일 경과 체크
			int pwResetDateFlag = loginService.getPwResetDate(param);
			if(pwResetDateFlag == 0) {
				utilService.logForJob("LoginFail", "com.st_ones.common.login.service.LoginService", "LoginFail", "Login", "패스워드 변경일자 180일 경과", "F", userId, ipAddress, "", "P");
				loginResultType = LoginResultType.WRONG_PASSWORD_RESET_DATE;
			}
		}

		processCommonMobileLogin(req, resp, loginResultType, resultInfo);
	}

	private void processCommonMobileLogin(EverHttpRequest req, EverHttpResponse resp, LoginResultType loginResultType, Map<String, UserInfo> resultInfo) throws Exception {

		if (loginResultType == LoginResultType.SUCCESS) { // 성공

			getLog().info("Creating User Session");
			createLoginUserSession(req, resp, resultInfo);

			Map<String, String> userInfo = new HashMap<String, String>();
			userInfo.put("GATE_CD", resultInfo.get("baseInfo").getGateCd());
			userInfo.put("USER_ID", resultInfo.get("baseInfo").getUserId());
			userInfo.put("LANG_CD", resultInfo.get("baseInfo").getLangCd());
			Boolean userSessionChk = userSession(req, resp, resultInfo, userInfo);

			if (userSessionChk) {
				resp.setParameter("message", "이미 로그인 된 사용자 입니다. 접속하실 수 없습니다.");
			} else {
				//로그인일시 업데이트
				loginService.setLastLoginDate(userInfo, req);
			}
		}
		else if (loginResultType == LoginResultType.FAIL_NOT_EXIST_ID) {  // 아이디 미존재
			resp.setParameter("message", "사용자 ID 또는 비밀번호를 확인해 주십시오.");
			resp.setParameter("failType", "N");
			resp.setResponseMessage("사용자 ID 또는 비밀번호를 확인해 주십시오.");
		}
		else if(loginResultType == LoginResultType.FAIL_WRONG_PASSWORD) { // 비밀번호 실패시
			resp.setParameter("message", "사용자 ID 또는 비밀번호를 확인해 주십시오.");
			resp.setParameter("failType", "FAIL_WRONG_PASSWORD");
			resp.setResponseMessage("사용자 ID 또는 비밀번호를 확인해 주십시오.");
		}
		// 비밀번호를 5회 이상 잘못 입력시
		else if (loginResultType == LoginResultType.WRONG_PASSWORD_EXCEEDED_CNT) {
			Map<String, String> param = new HashMap<String, String>();
			param.put("GATE_CD", resultInfo.get("baseInfo").getGateCd());
			param.put("USER_ID", resultInfo.get("baseInfo").getUserId());
			int passwordWrongCount = loginService.getPasswordWrongCount(param);

			resp.setResponseCode("WRONG_PASSWORD_EXCEEDED_CNT");
			resp.setResponseMessage("비밀번호 " + passwordWrongCount + "회 불일치로 계정 잠금 처리 되었습니다.\n계정 잠금 해제 하시겠습니까?");
		}
		// 최종로그인 90일이 지나면
		/*else if (loginResultType == LoginResultType.FAIL_LOGIN_DATE_PASS) {
			resp.setResponseCode("FAIL_LOGIN_DATE_PASS");
			resp.setResponseMessage("최종 로그인 90일 경과하여 휴면 계정입니다.\n계정 잠금 해제 하시겠습니까?");
		}*/
		// PW_RESET_FLAG 체크
		else if (loginResultType == LoginResultType.WRONG_PASSWORD_RESET_FLAG) {
			resp.setResponseCode("WRONG_PASSWORD_RESET_FLAG");
			resp.setResponseMessage("비밀번호가 초기화 되었습니다.\n비밀번호를 변경하시기 바랍니다.");
		}
		// 비밀번호 180일 변경일 체크
		else if (loginResultType == LoginResultType.WRONG_PASSWORD_RESET_DATE) {
			resp.setResponseCode("WRONG_PASSWORD_RESET_DATE");
			resp.setResponseMessage("비밀번호 변경일이 180일 초과 하였습니다.\n비밀번호를 변경하시기 바랍니다.");
		}
		else if(loginResultType == LoginResultType.NOT_APPROVAL) { // 승인되지 않은 사용자
			resp.setParameter("message", "승인되지 않은 사용자 입니다. 관리자에게 문의 바랍니다.");
			resp.setParameter("failType", "NOT_APPROVAL");
			resp.setResponseMessage("승인되지 않은 사용자 입니다. 관리자에게 문의 바랍니다.");
		}
		else if(loginResultType == LoginResultType.NOT_USE_FLAG) { // 사용불가 사용자
			resp.setParameter("message", "시스템을 사용할 수 없는 사용자 입니다. 관리자에게 문의 바랍니다.");
			resp.setParameter("failType", "NOT_USE_FLAG");
			resp.setResponseMessage("시스템을 사용할 수 없는 사용자 입니다. 관리자에게 문의 바랍니다.");
		}
	}

	private Boolean userSession(EverHttpRequest req, EverHttpResponse resp, Map<String, UserInfo> resultInfo, Map<String, String> userInfo) throws Exception {

		LoginManager loginManager = null;
		HttpSession httpSession = req.getSession();

