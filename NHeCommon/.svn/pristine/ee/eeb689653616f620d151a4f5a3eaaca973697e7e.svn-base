	public LoginResultType mobileLogin(LoginSearch loginSearch, Map<String, UserInfo> resultInfo) {

		UserInfo userInfo = loginMapper.getMobile_UserInfo(loginSearch);
		resultInfo.put("baseInfo", userInfo);

		if(userInfo == null) {
			return LoginResultType.FAIL_NOT_EXIST_ID;
		}

		//승인된 사용자 체크
		if(! userInfo.getProgressCd().equals("E")) {
			return LoginResultType.NOT_APPROVAL;
		}

		//사용여부 체크
		if(! userInfo.getUseFlag().equals("1")) {
			return LoginResultType.NOT_USE_FLAG;
		}

		if( userInfo == null || !userInfo.isPwdValid() ){
			return LoginResultType.FAIL_WRONG_PASSWORD;
		}

		return LoginResultType.SUCCESS;

	}

