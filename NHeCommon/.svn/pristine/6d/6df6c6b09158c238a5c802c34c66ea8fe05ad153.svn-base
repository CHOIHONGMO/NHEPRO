    /** 이유진 추가 - FileUtils.copyFile(tempFile, targetFile); 사용 시 출발지,목적지 파일 간 길이가 달라 Failed to copy full contents from 생김.
     *  File Lock 기능 추가
     *   */
    private static final int s_eof = -1;
    private static final int s_byteBuffer = 10240;

    private static void checkAndUpdateFile(File src, File dest) throws IOException {
      FileInputStream in = new FileInputStream(src);
      FileChannel srcChannel = in.getChannel();
      FileChannel destChannel = null;
      FileLock destLock = null;

      try {
        if (!dest.exists()) {
          final RandomAccessFile destFile = new RandomAccessFile(dest, "rw");
          destChannel = destFile.getChannel();
          destLock = destChannel.lock();
          copyFileChannels(srcChannel, destChannel);
          dest.setLastModified(src.lastModified());
        } else {
          final RandomAccessFile destFile = new RandomAccessFile(dest, "rw");
          destChannel = destFile.getChannel();
          destLock = destChannel.lock();
          if (!compareFileChannels(srcChannel, destChannel)) {
            copyFileChannels(srcChannel, destChannel);
            dest.setLastModified(src.lastModified());
          }
        }
      } finally {
        if (destLock != null) {
          destLock.release();
        }
        if (destChannel != null) {
          destChannel.close();
        }
        srcChannel.close();
        in.close();
      }
    }

    protected static void copyFileChannels(FileChannel src, 
                                           FileChannel dest) throws IOException {
      final long size = src.size();
      for (long pos = 0; pos < size; ) {
        long count = 
          ((size - pos) > s_byteBuffer) ? s_byteBuffer : (size - pos);
        pos += dest.transferFrom(src, pos, count);
      }
    }

    protected static boolean compareFileChannels(FileChannel a, 
                                                 FileChannel b) throws IOException {
      if (a.size() != b.size()) {
        return false;
      } else {
        final ByteBuffer aBuffer = ByteBuffer.allocate(s_byteBuffer);
        final ByteBuffer bBuffer = ByteBuffer.allocate(s_byteBuffer);
        for (int aCh = a.read(aBuffer); s_eof != aCh; ) {
          int bCh = b.read(bBuffer);
          if (aCh != bCh || aBuffer.compareTo(bBuffer) != 0) {
            return false;
          }
          aBuffer.clear();
          aCh = a.read(aBuffer);
          bBuffer.clear();
        }
        return s_eof == b.read(bBuffer);
      }
    }
    
    @RequestMapping(value = "/tempPdfUpdate")
    public void tempPdfUpdate(EverHttpRequest req, EverHttpResponse resp) throws Exception {
        req.setCharacterEncoding("utf-8"); // 주의:한글 파일명의 경우 flex에서 utf-8로 올려보냄 , euc-kr 일경우 선언 필요

        Map<String, String> param = req.getParamDataMap();
        System.out.println("ajkajk eformPdfUploadparam" + param.toString());
        
        /*

        String bizType = param.get("bizType");
        String buyerCd = param.get("buyerCd");
        String prBuyerCd = param.get("prBuyerCd");
        String prDeptCd = param.get("prDeptCd");
        String fileName = param.get("fileNm");
        String fileExtension = param.get("fileExtension");
        Integer fileCnt = Integer.parseInt(EverString.isEmpty(param.get("fileCnt"))?"0":param.get("fileCnt"));
        Integer maxFileCnt = Integer.parseInt(EverString.isEmpty(param.get("maxFileCnt"))?"0":param.get("maxFileCnt"));
        String fileType = param.get("fileType");

        if (EverString.isEmpty(bizType)) throw new NoResultException("Biz type is required.");

        // Session의 CompanyCd_DeptCd 를 받아서 폴더를 만든다.
        UserInfo userInfo = (UserInfo)req.getSession().getAttribute("ses");
        String deptCd = StringUtils.isEmpty(userInfo.getDeptCd().trim()) ? "0000" : userInfo.getDeptCd();
        String lastPath = "";

        if (EverString.isNotEmpty(prBuyerCd) && EverString.isNotEmpty(prDeptCd)) {
            lastPath = prBuyerCd + "_" + prDeptCd;
        } else {
            lastPath = userInfo.getCompanyCd() + "_" + deptCd;
        }

        String uuid = req.getParameter("uuid");
        String uuidSeq = null;

        if(EverString.isEmpty(uuid)) {
            uuid = fileAttachService.getUUID();

            synchronized (this) {
                Thread.sleep(2);
                uuidSeq = String.valueOf(System.currentTimeMillis());
            }
        } else {
            Map<String, String> fileInfo = fileAttachService.getFileInfo(uuid, null);
            uuid = fileInfo.get("UUID");
            uuidSeq = fileInfo.get("UUID_SQ");
        }

        String tempDirectory = PropertiesManager.getString("oz.source.file.path"); // 파일 임시 저장소
        String targetDirectory = "";
        if(bizType.equals("EC")) {
            targetDirectory = getFileUploadPath(bizType) + bizType + "/" + lastPath + "/"; // 파일 저장소
        } else {
            targetDirectory = getFileUploadPath(bizType) + EverDate.getYear() + "/" + EverDate.getYear()+EverDate.getMonth() + "/" + bizType + "/" + lastPath + "/"; // 파일 저장소
        }

        // 폴더 여부를 확인하여 생성한다.
        EverFile.makeDir(targetDirectory);
        String targetFileNm = uuid + "_" + uuidSeq + "." + fileExtension;
        String tempDirectoryFilePath = tempDirectory + fileExtension + "/" + fileName + "." + fileExtension;
        String targetFilePath = targetDirectory + targetFileNm;

        boolean isEncryptFile = false;
        boolean useFileDecryptionModule = PropertiesManager.getBoolean("everf.file.use.security.module");
        logger.info("첨부파일 암호화 여부가 [{}]로 설정되어 있습니다. ", useFileDecryptionModule);

        File tempFile = new File(tempDirectoryFilePath);
        File targetFile = new File(targetFilePath);

        if(useFileDecryptionModule) {

            String tempFilePath = tempFile.getPath();

            if(DRMUtils.isDRMSupportFile(tempFilePath)) {

                isEncryptFile = DRMUtils.isEncryptedFile(tempFilePath);
                if (isEncryptFile) {

                    logger.info("{}는 암호화된 파일입니다.", tempFilePath);

                    // 파일 존재여부 확인 후 존재하면 삭제
                    if(targetFile.isFile()) {
                        logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                        targetFile.delete();
                    }

                    logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());

                    //FileUtils.copyFile(tempFile, targetFile);
                    checkAndUpdateFile(tempFile, targetFile);
                    if (targetFile.exists()) {
                        logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
                    }

                } else {

                    logger.info("[{}] 파일은 암호화되지 않아 암호화를 진행합니다.", tempFile.getPath());

                    logger.info("-> SRC FILE PATH:" + tempFile.getPath());
                    logger.info("-> TGT FILE PATH:" + targetFile.getPath());

                    // 파일 존재여부 확인 후 존재하면 삭제
                    if(targetFile.isFile()) {
                        logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                        targetFile.delete();
                    }

                    logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());
                    //FileUtils.copyFile(tempFile, targetFile);
                    checkAndUpdateFile(tempFile, targetFile);
                    
                    if (DRMUtils.encryptFile(tempFile.getPath(), targetFile.getPath(), fileName, userInfo)) {
                        if (targetFile.exists()) {
                            logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
                        }
                    }
                }
            } else {

                // 파일 존재여부 확인 후 존재하면 삭제
                if(targetFile.isFile()) {
                    logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                    targetFile.delete();
                }

                logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());
                //FileUtils.copyFile(tempFile, targetFile);
                checkAndUpdateFile(tempFile, targetFile);
                if (targetFile.exists()) {
                    logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
                }
            }

        } else {

            // 파일 존재여부 확인 후 존재하면 삭제
            if(targetFile.isFile()) {
                logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                targetFile.delete();
            }

            logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());
            //FileUtils.copyFile(tempFile, targetFile);
            checkAndUpdateFile(tempFile, targetFile);
            if (targetFile.exists()) {
                logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
            }
        }

        String fileSize = EverFile.getFileSize(targetDirectory, uuid + "_" + uuidSeq + "." + fileExtension);

        HashMap<String, String> fileSaveInfo = getFileSaveInfo(bizType, targetDirectory, fileName, fileExtension, uuid, uuidSeq, fileSize, isEncryptFile);

        fileSaveInfo.put("PR_BUYER_CD", (prBuyerCd==null || "".equals(prBuyerCd)) ? userInfo.getCompanyCd() : prBuyerCd   );
        fileSaveInfo.put("PR_DEPT_CD", (prDeptCd==null || "".equals(prDeptCd)) ? userInfo.getDeptCd() : prDeptCd   );

      
        System.out.println("fileSaveInfo: "+ fileSaveInfo.toString());
        if(bizType.equals("EC")) { // 계약서 작성인 경우 파일 해시 값을 저장한다.
            fileSaveInfo.put("HASH_NUM", EverFile.fileToHash(targetFile));
        }

        if(EverString.isEmpty(req.getParameter("uuid"))) {
            fileAttachService.insertFileInfo(fileSaveInfo);
        } else {
            fileAttachService.updateFileInfo(fileSaveInfo);
        }

        if(fileCnt == maxFileCnt) {
            FileUtils.forceDelete(tempFile);
        }
        if (bizType.equals("EC")) {
            fileSaveInfo.put("CONT_NUM", param.get("CONT_NUM"));
            fileSaveInfo.put("CONT_CNT", param.get("CONT_CNT"));
            fileSaveInfo.put("BUYER_CD", buyerCd);
            fileSaveInfo.put("PR_BUYER_CD", prBuyerCd);
