	@Transactional(propagation = Propagation.REQUIRED, rollbackFor = Exception.class)
	public String ConfirmAgree(Map<String, String> param) throws Exception {

		String userType = EverString.nullToEmptyString(param.get("USER_TYPE"));
		if(userType.equals(Code.OPERATOR)) {
			loginMapper.ConfirmAgree(param);	//운영사
		}
		else {
			loginMapper.ConfirmAgree_BS(param);	//고객사,공급사
		}
		
		return "SUCCESS";
	}
	
	/**
	 * 2021.02.17 추가
	 * 시스템 이용료에 대한 수수료 청구 동의서
	 * @param param
	 * @return
	 * @throws Exception
	 */
	@Transactional(propagation = Propagation.REQUIRED, rollbackFor = Exception.class)
	public String systemConfirmAgree(Map<String, String> param) throws Exception {
		
		String userType = EverString.nullToEmptyString(param.get("USER_TYPE"));
		if(userType.equals(Code.OPERATOR)) {
			loginMapper.ConfirmAgree(param);	//운영사
		}
		else {
			loginMapper.ConfirmAgree_BS(param);	//고객사, 공급사
		}
		param.put("OPERATOR_CD", PropertiesManager.getString("eversrm.default.company.code"));
		loginMapper.ConfirmAgreeSV(param);		//이용계약서 및 전자서명값 저장
		
		return "SUCCESS";
	}
	
