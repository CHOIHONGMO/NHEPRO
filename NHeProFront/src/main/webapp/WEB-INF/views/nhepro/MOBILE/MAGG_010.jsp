        $(function () { 
            $(".cbox h3").on("click", function (e) {
                if ($(this).parent().has(".content-scroll")) {
                    e.preventDefault();                }
                if (!$(this).hasClass("open")) {                    
                    $(".content-scroll").slideUp(350);
                    $(".cbox h3").removeClass("open");                  
                    $(this).next(".content-scroll").slideDown(350);
                    $(this).addClass("open");
                }
                else if ($(this).hasClass("open")) {
                    $(this).removeClass("open");
                    $(this).next(".content-scroll").slideUp(350);
                }
            });
        });
    </script>

    
