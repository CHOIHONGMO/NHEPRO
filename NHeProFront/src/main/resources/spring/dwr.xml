<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:dwr="http://www.directwebremoting.org/schema/spring-dwr"
       xsi:schemaLocation="http://www.directwebremoting.org/schema/spring-dwr http://www.directwebremoting.org/schema/spring-dwr-3.0.xsd
		http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-3.0.xsd">
    <!-- DWR Controller -->
    <context:annotation-config />
    <!-- <dwr:configuration/> -->

    <dwr:controller id="dwrController" debug="true" >
        <dwr:config-param name="activeReverseAjaxEnabled" value="true" />
    </dwr:controller>

    <bean class="org.springframework.web.servlet.handler.SimpleUrlHandlerMapping">
        <property name="order" value="0" />
        <property name="alwaysUseFullPath" value="true" />
        <property name="mappings">
            <props>
                <prop key="/dwr/*/">dwrController</prop>
            </props>
        </property>
    </bean>

    <bean class="org.springframework.web.servlet.mvc.SimpleControllerHandlerAdapter" />
    <dwr:url-mapping />

    <!-- 	<bean id="reverseAuction" class="com.st_ones.common.serverpush.reverseajax.ReverseAuction">
            <dwr:remote javascript="ReverseAuction">
                <dwr:include method="clientCall" />
            </dwr:remote>
        </bean> -->

    <!-- <dwr:annotation-scan base-package="dwr.serverpush.reverseajax" scanDataTransferObject="false" scanRemoteProxy="true"/> -->

    <bean id="everAlarm" class="com.st_ones.common.serverpush.reverseajax.EverAlarm">
        <dwr:remote javascript="everAlarm"/>
    </bean>
</beans>