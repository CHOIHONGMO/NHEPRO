	/**
	 * 사용자 생성
	 * @param userId
	 * @throws Exception
	 */
	@Transactional(propagation = Propagation.REQUIRED, rollbackFor = Exception.class)
	public void createUser(String userId) throws Exception {
		Map<String,String> param = new HashMap<String,String>();
		param.put("USER_ID", userId);
		Map<String, String> interUserData = loginMapper.chkTbCoUser(param);
		if (interUserData == null) {
			throw new Exception("사용자가 존재하지 않습니다. 관리자에게 문의하세요.");
		} else {
			Map<String, String> interOrgData = loginMapper.chkTbCoBrc(interUserData);
			if (interOrgData == null) {
				throw new Exception("사용자 부서가 존재하지 않습니다. 관리자에게 문의하세요.");
			} else {
				Map<String, String> interCustData = loginMapper.chkTbCoCorp(interOrgData);
				if (interCustData == null) {
					throw new Exception("사용자 고객사가 존재하지 않습니다. 관리자에게 문의하세요.");
				} else {
					//System.err.println("====================================================1");
					String custCd = "";
					Map<String, String> cust = loginMapper.chkCust(interCustData);
					//System.err.println("====================================================2");
					if (cust == null ) { // 고객사가 존재하지 않으면

						throw new Exception("사용자 고객사가 존재하지 않습니다. 관리자에게 문의하세요.");


//						custCd = docNumService.getDocNumber("1000", "CUST");   //채번
//						interCustData.put("CUST_CD", custCd);
//						interOrgData.put("CUST_CD", custCd);
//						interUserData.put("CUST_CD", custCd);
//						//System.err.println("====================================================2.5");
//						loginMapper.insCust(interCustData);
//						//System.err.println("====================================================2.7");
					} else {
						custCd = cust.get("CUST_CD");
						interOrgData.put("CUST_CD", custCd);
						interUserData.put("CUST_CD", custCd);
					}
					interOrgData.put("CORP_NO", interCustData.get("CORP_NO"));
					interUserData.put("CORP_NO",interCustData.get("CORP_NO"));

					//System.err.println("====================================================3");

					Map<String, String> ogdp = loginMapper.chkOgdp(interOrgData);
					//System.err.println("====================================================4");
					if (ogdp == null ) { // 부서가 존재하지 않으면
						loginMapper.insOgdp(interOrgData);
					}

					Map<String, String> user = loginMapper.chkCvur(interUserData);
					if (user == null ) { // 유저가 존재하지 않으면
						interUserData.put("PASSWORD",EverEncryption.getEncryptedUserPassword(interUserData.get("USER_ID").toUpperCase()));
						loginMapper.insCvur(interUserData);
						loginMapper.insUsap(interUserData); // 메류프로파일

						interUserData.put("CORP_TYPE", interCustData.get("NH_CORP_CODE"));
						loginMapper.insBacp(interUserData); // 직무매핑
					}
				}
			}
		}
		//if (1==1) throw new Exception("TEST. 관리자에게 문의하세요.");

	}



