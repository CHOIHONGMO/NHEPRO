				<td style='word-break:break-all;border-left:1px solid #cdcdcd;border-right:1px solid #cdcdcd;border-bottom:1px solid #cdcdcd;text-align:left;padding-left:6px;color:#404141;font-size:12px'>$TEL_NUM$</td>
			</tr>
			</tbody>
		</table>
	</div>
	<br>
	<strong style='display:block;height:22px;padding:0 0 0 20px;font-size:13px;color:#232323;background:url($maintainUrl$/images/ymro/mail/ico_title.gif) 0 3px no-repeat'>품목정보</strong>
