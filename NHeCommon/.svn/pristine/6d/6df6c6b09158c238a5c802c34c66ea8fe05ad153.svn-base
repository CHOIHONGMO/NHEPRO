                    String domainUrl = PropertiesManager.getString("eversrm.system.domainUrl");
                    resp.getWriter().write("<script type='text/javascript'>location.href='/welcome.so?returnUrl="+URLEncoder.encode(domainUrl+req.getRequestURI()+"?"+req.getQueryString(), "UTF-8")+"';</script>");
                    resp.getWriter().flush();
                    resp.getWriter().close();
                    return;
                }

            }

