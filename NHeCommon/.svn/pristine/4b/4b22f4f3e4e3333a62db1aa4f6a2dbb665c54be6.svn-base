		if (PropertiesManager.getBoolean("eversrm.system.DuplicateSessionFlag", false)) {
			loginManager = LoginManager.getInstance();
			// httpSession.removeAttribute(userInfo.get("USER_ID"));

			if (loginManager.isUsing(userInfo.get("USER_ID"))) {
				// loginManager.removeSession(userInfo.get("USER_ID"));
				return true;
			}
			loginManager.setSession(httpSession, userInfo.get("USER_ID"));
		}

		return false;
