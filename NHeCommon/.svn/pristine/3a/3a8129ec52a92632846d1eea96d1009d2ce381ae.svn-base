<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.eversrm.eApproval.eApprovalEnd.ESTM.EApprovalEndESTM_Mapper">

    <select id="getBdesNum" parameterType="hashMap" resultType="hashMap">
        SELECT GATE_CD
				,BUYER_CD
				,BID_NUM
				,TO_CHAR(BID_CNT)  BID_CNT
          FROM STOCBDES
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND APP_DOC_NUM = #{APP_DOC_NUM}
           AND APP_DOC_CNT = #{APP_DOC_CNT}
    </select>

    <update id="setBdesSignStatus" parameterType="hashmap">

        UPDATE STOCBDES SET
             SIGN_STATUS = #{SIGN_STATUS}
        <if test='SIGN_STATUS == "E" or SIGN_STATUS == "R"'>
            ,SIGN_DATE = SYSDATE
        </if>
         WHERE GATE_CD = #{ses.gateCd}
           AND BUYER_CD = #{BUYER_CD}
           AND BID_NUM = #{BID_NUM}
           AND BID_CNT = #{BID_CNT}

    </update>

    <update id="setPrProgressCd" parameterType="hashmap">

		UPDATE STOCPRDT SET
			PROGRESS_CD = '2100'
         WHERE GATE_CD = #{ses.gateCd}
           AND PR_NUM = #{PR_NUM}
           AND BUYER_CD = #{BUYER_CD}
           AND DEL_FLAG = '0'

    </update>


</mapper>