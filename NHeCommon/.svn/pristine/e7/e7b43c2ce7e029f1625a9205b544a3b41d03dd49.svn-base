package com.st_ones.eversrm.manager.system.web;

import com.st_ones.common.cache.data.CacheUtil;
import com.st_ones.common.message.service.MessageService;
import com.st_ones.everf.serverside.config.PropertiesManager;
import com.st_ones.everf.serverside.web.BaseController;
import com.st_ones.everf.serverside.web.wrapper.EverHttpRequest;
import com.st_ones.everf.serverside.web.wrapper.EverHttpResponse;
import org.apache.commons.lang3.StringUtils;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.RequestMapping;

import java.util.Iterator;
import java.util.Map;

/**
 * <pre>
 ******************************************************************************
 * 상기 프로그램에 대한 저작권을 포함한 지적재산권은 ㈜에스티원즈에 있으며,
 * ㈜에스티원즈가 명시적으로 허용하지 않은 사용, 복사, 변경, 제3자에의 공개, 배포는 엄격히 금지되며,
 * ㈜에스티원즈의 지적재산권 침해에 해당됩니다.
 * (Copyright ⓒ 2013 ST-ONES CORP., ALL RIGHTS RESERVED | Confidential)
 ******************************************************************************
 * </pre>
 * @File Name : MSYA0020_Controller.java
 * @date 2013. 07. 22.
 * @version 1.0
 */

@Controller
@RequestMapping(value = "/eversrm/manager/system")
public class MSYA0020_Controller extends BaseController {

	@Autowired private MessageService msg;

	@Autowired private CacheUtil cacheUtil;

	/**
	 * 화면명 : Cache Reload
	 * 처리내용 : 공통코드 등 Server의 cache에 담기는 데이터의 등록/수정/삭제가 이루어지는 경우, Server cache를 reload 하는 화면.
	 * 경로 : 시스템관리 > 시스템 > Cache Reload
	 */
	@RequestMapping(value = "/MSYA0020/view")
	public String MSYA0020(EverHttpRequest req) {

		Map<String, String> propertiesByPrefixAsMap = PropertiesManager.getPropertiesByPrefixAsMap("everF.cacheEnable");
		Iterator<String> iterator = propertiesByPrefixAsMap.keySet().iterator();
		while (iterator.hasNext()) {
			String key = iterator.next();
			String value = propertiesByPrefixAsMap.get(key);
			req.setAttribute(StringUtils.replace(key, ".", "_"), value);
		}
		return "/eversrm/manager/system/MSYA0020";
	}

	@RequestMapping(value = "/MSYA0020/cacheSync")
	public void msya0020_cacheSync(EverHttpRequest req, EverHttpResponse resp) throws Exception {
		cacheUtil.initCacheCode();
		cacheUtil.loadCacheData();
		PropertiesManager.refresh();
		resp.setResponseMessage(msg.getMessage("0001"));
	}

}