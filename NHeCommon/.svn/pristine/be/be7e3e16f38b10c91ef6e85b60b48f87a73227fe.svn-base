<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.common.util.LargeTextMapper">

	<!-- LargeTextCLOB -->
    <insert id="insertLargeText">
        INSERT INTO STOCTXTH <if test="_databaseId == 'mssql'">with (ROWLOCK)</if> (
            GATE_CD, TEXT_NUM, TEXT_CONTENTS, REG_DATE)
        VALUES(
            <choose>
                <when test="ses.gateCd == null or ses.gateCd == ''">'100',</when>
                <otherwise>#{ses.gateCd},</otherwise>
            </choose>
            #{TEXT_NUM}, #{RICH_TEXT_EDIT}, SYSDATE)
    </insert>

    <update id="updateLargeText">
        UPDATE STOCTXTH <if test="_databaseId == 'mssql'">with (ROWLOCK)</if>
           SET TEXT_CONTENTS = #{RICH_TEXT_EDIT},
               REG_DATE = SYSDATE
         WHERE GATE_CD = <choose>
                             <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                             <otherwise>#{ses.gateCd}</otherwise>
                         </choose>
           AND TEXT_NUM = #{TEXT_NUM}
    </update>

    <select id="selectLargeText" parameterType="hashMap" resultType="java.lang.String">

        SELECT TEXT_CONTENTS
          FROM STOCTXTH
         WHERE GATE_CD = <choose>
                             <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                             <otherwise>#{ses.gateCd}</otherwise>
                         </choose>
           AND TEXT_NUM = #{TEXT_NUM}
    </select>
    
	<!-- LargeTextSplitString -->
    <select id="selectTXTD" parameterType="hashMap" resultType="java.lang.String">

        SELECT TEXT_CONTENTS
          FROM STOCTXTD
         WHERE TEXT_NUM = #{TEXT_NUM}
           AND GATE_CD = <choose>
                             <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                             <otherwise>#{ses.gateCd}</otherwise>
                         </choose>
         ORDER BY TEXT_SQ
    </select>
	
	<!-- 2021.02.23 추가 -->
	<!-- TXTH의 TEXT_CONTENTS 컬럼에 내용 인증값이 있는경우 등록 -->
    <insert id="insertTXTH" parameterType="hashmap">
        INSERT INTO STOCTXTH (
            GATE_CD, TEXT_NUM, TEXT_CONTENTS, VID_RANDOM, IRS_NUM, REG_DATE)
        VALUES(
            <choose>
                <when test="ses.gateCd == null or ses.gateCd == ''">'100',</when>
                <otherwise>#{ses.gateCd},</otherwise>
            </choose>
            #{TEXT_NUM}, #{TEXT_SIGN_CONTENTS}, #{VID_RANDOM}, #{IRS_NUM}, SYSDATE)
    </insert>
    
    <select id="getTextSq" parameterType="hashMap" resultType="java.lang.String">

        SELECT <include refid="common.sql.nvl"/>(MAX(TEXT_SQ), 0) + 1
          FROM STOCTXTD
         WHERE GATE_CD = <choose>
                            <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                            <otherwise>#{ses.gateCd}</otherwise>
                         </choose>
           AND TEXT_NUM = #{TEXT_NUM}
    </select>

    <insert id="insertTXTD" parameterType="hashMap">

        INSERT INTO STOCTXTD (
            GATE_CD, TEXT_NUM, TEXT_SQ, TEXT_CONTENTS)
        VALUES(
            <choose>
                <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                <otherwise>#{ses.gateCd}</otherwise>
            </choose>
            , #{TEXT_NUM}
            , #{TEXT_SQ}
            , #{RICH_TEXT_EDIT})
    </insert>
	
	<update id="updateTXTH" parameterType="hashmap">
        UPDATE STOCTXTH
           SET REG_DATE = SYSDATE
             , TEXT_CONTENTS = #{TEXT_SIGN_CONTENTS}
             , VID_RANDOM = #{VID_RANDOM}
             , IRS_NUM = #{IRS_NUM} 
         WHERE GATE_CD = <choose>
                             <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                             <otherwise>#{ses.gateCd}</otherwise>
                         </choose>
           AND TEXT_NUM = #{TEXT_NUM}
    </update>

    <delete id="deleteTXTD" parameterType="hashmap">

        DELETE STOCTXTD <if test="_databaseId == 'mssql'">with (ROWLOCK)</if>
         WHERE GATE_CD = <choose>
                            <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                            <otherwise>#{ses.gateCd}</otherwise>
                        </choose>
           AND TEXT_NUM = #{TEXT_NUM}
    </delete>

    <!-- LargeText For Mail -->
    <insert id="insertMailContents" parameterType="hashmap">

        INSERT INTO STOCMATX (
            GATE_CD, TEXT_NUM, MAIL_CONTENTS, REG_DATE)
        VALUES(
            <choose>
                <when test="ses.gateCd == null or ses.gateCd == ''">'100',</when>
                <otherwise>#{ses.gateCd},</otherwise>
            </choose>
            #{TEXT_NUM}, #{MAIL_CONTENTS}, SYSDATE)
    </insert>

    <select id="selectMailContents" parameterType="hashMap" resultType="java.lang.String">

        SELECT MAIL_CONTENTS
          FROM STOCMATX
         WHERE GATE_CD = <choose>
                             <when test="ses.gateCd == null or ses.gateCd == ''">'100'</when>
                             <otherwise>#{ses.gateCd}</otherwise>
                         </choose>
           AND TEXT_NUM = #{TEXT_NUM}
    </select>

</mapper>