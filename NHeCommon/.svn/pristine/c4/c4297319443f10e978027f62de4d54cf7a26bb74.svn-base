    <select id="existsUserInformation_VNGL" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT
            COUNT(A.USER_ID) AS CNT
          FROM (
            SELECT GATE_CD, USER_ID FROM STOCCVUR
            UNION ALL
            SELECT GATE_CD, USER_ID AS USER_ID FROM STOCUSER
          ) A
         WHERE A.GATE_CD = #{ses.gateCd}
           AND A.USER_ID = UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_ID})))

    </select>
    
    <!-- 2022.11.17 파트너스 개인근로자 추가 -->
    <select id="existsUserInformation_TVUR" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT
            COUNT(A.USER_ID) AS CNT
          FROM (
            SELECT GATE_CD, USER_ID FROM STOCTVUR          
          ) A
         WHERE A.GATE_CD = #{ses.gateCd}
           AND A.USER_ID = UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_ID})))

    </select>

    <select id="existsMYNUser_VNGL" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT
            COUNT(CVUR.USER_ID) AS CNT
          FROM STOCCVUR CVUR
          JOIN STOCVNGL A
           ON (CVUR.GATE_CD = A.GATE_CD
           AND CVUR.COMPANY_CD = A.VENDOR_CD)
         WHERE CVUR.GATE_CD = #{ses.gateCd}
           AND CVUR.COMPANY_CD = #{COMPANY_CD}
           AND MNG_YN = '1'
           AND CVUR.USER_ID != #{USER_ID}

    </select>

    <select id="existsMYNUser_CUST" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT
            COUNT(CVUR.USER_ID) AS CNT
          FROM STOCCVUR CVUR
          JOIN STOCCUST A
           ON (CVUR.GATE_CD = A.GATE_CD
           AND CVUR.COMPANY_CD = A.CUST_CD)
         WHERE CVUR.GATE_CD = #{ses.gateCd}
           AND CVUR.COMPANY_CD = #{COMPANY_CD}
           AND MNG_YN = '1'
           AND CVUR.USER_ID != #{USER_ID}

    </select>

    <select id="CheckUserInfoPassWordSame" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT
            COUNT(USER_ID) AS CNT
          FROM STOCUSER
         WHERE GATE_CD = #{ses.gateCd}
           AND USER_ID = #{USER_ID}
           AND PASSWORD = #{PASSWORD}

    </select>

    <update id="updateUserInformation" parameterType="hashMap">

        UPDATE STOCUSER SET
        	 MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
            ,USE_FLAG = #{USE_FLAG}
            ,COMPANY_CD = #{COMPANY_CD}
            ,USER_TYPE = #{USER_TYPE}
            ,WORK_TYPE = #{WORK_TYPE}
            ,USER_NM = <include refid="common.sql.strEncStart"/>#{USER_NM}<include refid="common.sql.strEncEnd"/>
            ,USER_NM_ENG = <include refid="common.sql.strEncStart"/>#{USER_NM_ENG}<include refid="common.sql.strEncEnd"/>
        <if test="CHANGE_PW !='' and CHANGE_PW !=null">
            ,PASSWORD = #{PASSWORD} <!--<include refid="common.sql.dbo"/>setEncPassword(UPPER(#{PASSWORD}))-->
        </if>
            ,DEPT_CD = #{DEPT_CD}
            ,POSITION_NM = #{POSITION_NM}
            ,DUTY_NM = #{DUTY_NM}
            ,EMPLOYEE_NUM = #{EMPLOYEE_NUM}
            ,EMAIL = <include refid="common.sql.strEncStart"/>#{EMAIL}<include refid="common.sql.strEncEnd"/>
            ,TEL_NUM = <include refid="common.sql.strEncStart"/>#{TEL_NUM}<include refid="common.sql.strEncEnd"/>
            ,CELL_NUM = <include refid="common.sql.strEncStart"/>#{CELL_NUM}<include refid="common.sql.strEncEnd"/>
            ,FAX_NUM = <include refid="common.sql.strEncStart"/>#{FAX_NUM}<include refid="common.sql.strEncEnd"/>
            ,LANG_CD = <include refid="common.sql.nvl"/>(#{ses.langCd}, 'KO')
            ,COUNTRY_CD = <include refid="common.sql.nvl"/>(#{ses.countryCd}, 'KR')
            ,SUPER_USER_FLAG = #{SUPER_USER_FLAG}
            ,GMT_CD = <include refid="common.sql.nvl"/>(#{ses.userGmt}, 'GMT+09:00')
            ,PROGRESS_CD = #{PROGRESS_CD}
            ,DEL_FLAG = '0'
            ,USER_DATE_FORMAT_CD = <include refid="common.sql.nvl"/>(CASE WHEN #{USER_DATE_FORMAT_CD} = '' THEN NULL ELSE #{USER_DATE_FORMAT_CD} END, '01')
            ,USER_NUMBER_FORMAT_CD = <include refid="common.sql.nvl"/>(CASE WHEN #{USER_NUMBER_FORMAT_CD} = '' THEN NULL ELSE #{USER_NUMBER_FORMAT_CD} END, '01')
         WHERE GATE_CD = #{ses.gateCd}
           AND USER_ID = #{USER_ID}

    </update>

    <select id="CheckUserInfoPassWordSame_VNGL" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT COUNT(USER_ID)
          FROM STOCCVUR
         WHERE GATE_CD = #{ses.gateCd}
           AND USER_ID = UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_ID})))
           AND PASSWORD = #{PASSWORD}

    </select>
    
    <select id="CheckUserInfoPassWordSame_EMP" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT COUNT(USER_ID)
          FROM STOCTVUR
         WHERE GATE_CD = #{ses.gateCd}
           AND USER_ID = UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_ID})))
           AND PASSWORD = #{PASSWORD}

    </select>

    <update id="updateUserInformation_VNGL" parameterType="hashMap">

        UPDATE STOCCVUR SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
            ,COMPANY_CD = #{COMPANY_CD}
            ,MNG_YN = <include refid="common.sql.nvl"/>(#{SUPER_USER_FLAG}, '0')
            ,USER_NM = <include refid="common.sql.strEncStart"/>#{USER_NM}<include refid="common.sql.strEncEnd"/>
        <if test="CHANGE_PW !='' and CHANGE_PW !=null">
            ,PASSWORD = #{PASSWORD}
        </if>
            ,DEPT_NM = #{DEPT_NM}
            ,POSITION_NM = #{POSITION_NM}
            ,EMPLOYEE_NUM = #{EMPLOYEE_NUM}
            ,DUTY_NM = #{DUTY_NM}
            ,TEL_NUM = <include refid="common.sql.strEncStart"/>#{TEL_NUM}<include refid="common.sql.strEncEnd"/>
            ,FAX_NUM = <include refid="common.sql.strEncStart"/>#{FAX_NUM}<include refid="common.sql.strEncEnd"/>
            ,CELL_NUM = <include refid="common.sql.strEncStart"/>#{CELL_NUM}<include refid="common.sql.strEncEnd"/>
            ,EMAIL = <include refid="common.sql.strEncStart"/>#{EMAIL}<include refid="common.sql.strEncEnd"/>
            ,PROGRESS_CD = #{PROGRESS_CD}
            ,USE_FLAG = #{USE_FLAG}
            ,USER_TYPE = #{USER_TYPE}
        WHERE GATE_CD = #{ses.gateCd}
          AND USER_ID = UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_ID})))

    </update>

    <update id="doResetUserInfo" parameterType="hashMap">

        UPDATE STOCUSER SET
            LAST_LOGIN_DATE = SYSDATE
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_ID_ORI})))

    </update>

    <update id="doSaveIssue" parameterType="hashMap">

        UPDATE STOCUSER SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = <include refid="common.sql.nvl"/>(#{ses.userId}, 'SYSTEM')
            ,PASSWORD = #{PASSWORD} <!--<include refid="common.sql.dbo"/>setEncPassword(UPPER(#{PASSWORD}))-->
            ,PW_WRONG_CNT = 0
            ,PW_RESET_FLAG = '1'
            ,PW_RESET_DATE = SYSDATE
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID}

    </update>

    <update id="doSaveIssue_CVUR" parameterType="hashMap">

        UPDATE STOCCVUR SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
            ,PASSWORD = #{PASSWORD} <!--<include refid="common.sql.dbo"/>setEncPassword(UPPER(#{PASSWORD}))-->
            ,PW_WRONG_CNT = 0
            ,PW_RESET_FLAG = '1'
            ,PW_RESET_DATE = SYSDATE
         WHERE GATE_CD = #{ses.gateCd}
           AND USER_ID = #{USER_ID}

    </update>
    
    <update id="doSaveIssue_TVUR" parameterType="hashMap">

        UPDATE STOCTVUR SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
            ,PASSWORD = #{PASSWORD} <!--<include refid="common.sql.dbo"/>setEncPassword(UPPER(#{PASSWORD}))-->
            ,PW_WRONG_CNT = 0
            ,PW_RESET_FLAG = '1'
            ,PW_RESET_DATE = SYSDATE
         WHERE GATE_CD = #{ses.gateCd}
           AND USER_ID = #{USER_ID}

    </update>

    <select id="existsUSAP" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT COUNT(AUTH_CD) AS CNT FROM STOCUSAP
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID}
           AND AUTH_CD = #{AUTH_CD}

    </select>

    <delete id="RealdeleteUSAP" parameterType="hashmap">

        DELETE FROM STOCUSAP
         WHERE GATE_CD = #{ses.gateCd}
           AND USER_ID = #{USER_ID}

    </delete>

    <insert id="createUSAP" parameterType="hashMap">

		INSERT INTO STOCUSAP (
			  GATE_CD
            , USER_ID
            , AUTH_CD
            , REG_DATE
            , REG_USER_ID
            , MOD_DATE
            , MOD_USER_ID
            , DEL_FLAG
        <if test="VALID_FROM_DATE != '' and VALID_FROM_DATE != null">
            , VALID_FROM_DATE
        </if>
        <if test="VALID_TO_DATE != '' and VALID_TO_DATE != null">
            ,VALID_TO_DATE
        </if>
		) VALUES (
			  #{ses.gateCd}
            , UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_ID})))
            , #{AUTH_CD}
            , SYSDATE
            , #{ses.userId}
            , SYSDATE
            , #{ses.userId}
            , '0'
        <if test="VALID_FROM_DATE != '' and VALID_FROM_DATE != null">
            , <include refid="common.sql.toDate"/>(#{VALID_FROM_DATE}, 'yyyyMMdd')
        </if>
        <if test="VALID_TO_DATE != '' and VALID_TO_DATE != null">
            , <include refid="common.sql.toDate"/>(#{VALID_TO_DATE}, 'yyyyMMdd')
        </if>
		)

    </insert>

    <insert id="createBACP" parameterType="hashMap">

        MERGE <include refid="common.sql.mergeInto"/> STOCBACP BACP
        USING (SELECT #{ses.gateCd} AS GATE_CD
                   ,#{COMPANY_CD} AS BUYER_CD
                   ,'BASIC' AS CTRL_CD
                   ,#{USER_ID} AS CTRL_USER_ID <include refid="common.sql.dual"/>
        ) DATA
        ON (BACP.GATE_CD = DATA.GATE_CD
        AND BACP.BUYER_CD = DATA.BUYER_CD
        AND BACP.CTRL_CD = DATA.CTRL_CD
        AND BACP.CTRL_USER_ID = DATA.CTRL_USER_ID)
        WHEN MATCHED THEN
        UPDATE SET
             MOD_DATE = SYSDATE
            ,MOD_USER_ID = #{ses.userId}
            ,DEL_FLAG = '0'
        WHEN NOT MATCHED THEN
        INSERT (
             GATE_CD
            ,BUYER_CD
            ,CTRL_CD
            ,CTRL_USER_ID
            ,REG_DATE
            ,REG_USER_ID
            ,MOD_DATE
            ,MOD_USER_ID
            ,DEL_FLAG
            ,USE_FLAG
        ) VALUES (
             #{ses.gateCd}
            ,#{COMPANY_CD}
            ,'BASIC'
            ,#{USER_ID}
            ,SYSDATE
            ,#{ses.userId}
            ,SYSDATE
            ,#{ses.userId}
            ,'0'
            ,'1'
        )<include refid="common.sql.comma"/>

    </insert>

    <update id="updateUSAP" parameterType="hashMap">

        UPDATE STOCUSAP SET
              MOD_DATE = SYSDATE
            , MOD_USER_ID = #{ses.userId}
            , DEL_FLAG = '0'
        <if test="VALID_FROM_DATE != '' and VALID_FROM_DATE != null">
            , VALID_FROM_DATE = <include refid="common.sql.toDate"/>(#{VALID_FROM_DATE}, 'yyyyMMdd'))
        </if>
        <if test="VALID_TO_DATE != '' and VALID_TO_DATE != null">
            , VALID_TO_DATE = <include refid="common.sql.toDate"/>(#{VALID_TO_DATE}, 'yyyyMMdd'))
        </if>
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID}
           AND AUTH_CD = #{AUTH_CD}

    </update>

    <update id="doDeleteUSAP" parameterType="hashMap">

        UPDATE STOCUSAP SET
               MOD_DATE = SYSDATE
             , MOD_USER_ID = #{ses.userId}
             , DEL_FLAG = '1'
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID}

    </update>

    <select id="existsUSAC" parameterType="hashMap" resultType="java.lang.Integer">

        SELECT COUNT(ACTION_PROFILE_CD) FROM STOCUSAC
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID}
           AND ACTION_PROFILE_CD = #{ACTION_PROFILE_CD}

    </select>

    <insert id="createUSAC" parameterType="hashMap">

        INSERT INTO STOCUSAC (
        	  GATE_CD
            , USER_ID
            , ACTION_PROFILE_CD
            , REG_DATE
            , REG_USER_ID
            , MOD_DATE
            , MOD_USER_ID
            , DEL_FLAG
            , VALID_FROM_DATE
            , VALID_TO_DATE
		) VALUES (
			  #{ses.gateCd}
            , #{USER_ID}
            , #{ACTION_PROFILE_CD}
            , SYSDATE
            , #{ses.userId}
            , SYSDATE
            , #{ses.userId}
            , '0'
            , <include refid="common.sql.toDate"/>(#{VALID_FROM_DATE}, 'yyyyMMdd')
            , <include refid="common.sql.toDate"/>(#{VALID_TO_DATE}, 'yyyyMMdd')
		)

    </insert>

    <update id="updateUSAC" parameterType="hashMap">

        UPDATE STOCUSAC SET
			  VALID_FROM_DATE = <include refid="common.sql.toDate"/>(#{VALID_FROM_DATE}, 'yyyyMMdd')
           	, VALID_TO_DATE = <include refid="common.sql.toDate"/>(#{VALID_TO_DATE}, 'yyyyMMdd')
           	, MOD_DATE = SYSDATE
           	, MOD_USER_ID = #{ses.userId}
           	, DEL_FLAG = '0'
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID}
           AND ACTION_PROFILE_CD = #{ACTION_PROFILE_CD}

    </update>

    <update id="doDeleteUSAC" parameterType="hashMap">

        UPDATE STOCUSAC SET
               MOD_DATE = SYSDATE
           	 , MOD_USER_ID = #{ses.userId}
           	 , DEL_FLAG = '1'
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID}

    </update>

    <update id="doDeleteUserInfo" parameterType="hashMap">

        UPDATE STOCUSER SET
        	  DEL_FLAG = '1'
            , MOD_DATE = SYSDATE
            , MOD_USER_ID = #{ses.userId}
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID_ORI}

    </update>

    <update id="doDeleteUserInfoBS">

        UPDATE STOCCVUR
           SET DEL_FLAG = '1'
             , MOD_DATE = SYSDATE
             , MOD_USER_ID = #{ses.userId}
         WHERE GATE_CD = #{GATE_CD}
           AND USER_ID = #{USER_ID_ORI}

    </update>

	<select id="selectUserSearch" parameterType="hashmap" resultType="hashmap">

		SELECT DISTINCT
              USER_TBL.USER_ID AS USER_ID
			, USER_TBL.USER_TYPE
			, USER_TBL.COMPANY_CD
            ,(SELECT BUYER_NM FROM STOCOGCM WHERE GATE_CD = USER_TBL.GATE_CD AND BUYER_CD = USER_TBL.COMPANY_CD AND LANG_CD = #{ses.langCd}) AS BUYER_NM
			, OGDP.DEPT_CD
			, USER_TBL.POSITION_NM
			, USER_TBL.DUTY_NM
			, <include refid="common.sql.dbo"/>getUserName(USER_TBL.GATE_CD, USER_TBL.USER_ID, #{ses.langCd}) AS USER_NM
			, <include refid="common.sql.dbo"/>getUserName(USER_TBL.GATE_CD, USER_TBL.USER_ID, #{ses.langCd}) AS HIDDEN_USER_NM
			, <include refid="common.sql.dbo"/>getDeptName(USER_TBL.GATE_CD, USER_TBL.COMPANY_CD, USER_TBL.DEPT_CD, #{ses.langCd}) AS DEPT_NM
	     FROM STOCUSER USER_TBL
	     LEFT JOIN STOCOGCM OGCM
	      ON (USER_TBL.COMPANY_CD = OGCM.BUYER_CD
	      AND USER_TBL.GATE_CD = OGCM.GATE_CD
	      AND OGCM.DEL_FLAG = '0')
	     LEFT JOIN STOCOGDP OGDP
	      ON (USER_TBL.DEPT_CD = OGDP.DEPT_CD
	      AND USER_TBL.GATE_CD = OGDP.GATE_CD
	      AND USER_TBL.COMPANY_CD = OGDP.BUYER_CD
	      AND OGDP.DEL_FLAG = '0')
	    WHERE USER_TBL.GATE_CD = #{ses.gateCd}
	      AND USER_TBL.DEL_FLAG = '0'
	    <if test="USER_TYPE != '' and USER_TYPE != null">
	        AND USER_TBL.USER_TYPE = UPPER((<include refid="common.sql.dbo"/>SF_TRIM(#{USER_TYPE})))
	    </if>
	    <if test="BUYER_NM != '' and BUYER_NM != null">
	        AND UPPER((SELECT BUYER_NM FROM STOCOGCM WHERE GATE_CD = USER_TBL.GATE_CD AND BUYER_CD = USER_TBL.COMPANY_CD AND LANG_CD = #{ses.langCd})) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{BUYER_NM}) <include refid="common.sql.stringMerge"/> '%'
	    </if>
	    <if test="USER_NM != '' and USER_NM != null">
            AND UPPER(<include refid="common.sql.dbo"/>getUserName(USER_TBL.GATE_CD, USER_TBL.USER_ID, #{ses.langCd})) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{USER_NM}) <include refid="common.sql.stringMerge"/> '%'
	    </if>
	    <if test="DEPT_NM != '' and DEPT_NM != null">
	        AND UPPER(<include refid="common.sql.dbo"/>getDeptName(USER_TBL.GATE_CD, USER_TBL.COMPANY_CD, USER_TBL.DEPT_CD, #{ses.langCd})) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{DEPT_NM}) <include refid="common.sql.stringMerge"/> '%'
	    </if>

    </select>

    <select id="getUserInfo" parameterType="hashmap" resultType="hashmap">
       <if test="USER_TYPE == 'O'.toString()">
           SELECT GATE_CD
                 ,USER_ID AS USER_ID
                 ,<include refid="common.sql.strDecStart"/>USER_NM<include refid="common.sql.strDecEnd"/> AS USER_NM
                 ,<include refid="common.sql.strDecStart"/>CELL_NUM<include refid="common.sql.strDecEnd"/> AS CELL_NUM
                 ,COMPANY_CD
             FROM STOCUSER
            WHERE GATE_CD = '100'
              AND USER_ID = #{userId}
       </if>
       <if test="USER_TYPE == 'CS'.toString()">
           SELECT GATE_CD
                 ,USER_ID
                 ,<include refid="common.sql.strDecStart"/>USER_NM<include refid="common.sql.strDecEnd"/> AS USER_NM
                 ,<include refid="common.sql.strDecStart"/>CELL_NUM<include refid="common.sql.strDecEnd"/> AS CELL_NUM
                 ,COMPANY_CD
             FROM STOCCVUR
            WHERE GATE_CD = '100'
              AND USER_ID = #{userId}
       </if>
    </select>

</mapper>