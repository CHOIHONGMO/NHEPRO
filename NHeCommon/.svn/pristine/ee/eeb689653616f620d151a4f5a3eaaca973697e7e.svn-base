	@Transactional(propagation = Propagation.REQUIRED, rollbackFor = Exception.class)
	public LoginResultType login(LoginSearch loginSearch, Map<String, UserInfo> baseUserInfo) throws Exception {

		// 로그인 ID 체크
		String loginAttemptUserType = loginMapper.findUserId(loginSearch);
		if (StringUtils.isEmpty(loginAttemptUserType)) {
			// 휴먼계정 사용자인지 체크
			int userCnt = loginMapper.findNonUserId(loginSearch);

			if(userCnt > 0) {
				return LoginResultType.LONG_TERM_NON_USER;
			} else {
				return LoginResultType.FAIL_NOT_EXIST_ID;
			}
		}
		else if ("999".equals(loginAttemptUserType)) {
			return LoginResultType.FAIL_NOT_EXIST_USER_TYPE;
		}
		else {
			loginSearch.setUserType(loginAttemptUserType);
		}

		loginSearch.setDatabaseCd(PropertiesManager.getString("eversrm.system.database"));
		loginSearch.setGmtDefault(PropertiesManager.getString("eversrm.gmt.default"));
		loginSearch.setLangCd(PropertiesManager.getString("eversrm.langCd.default"));

		// 운영사 로그인정보
		if(loginSearch.getSiteType() != null && loginSearch.getSiteType().equals(Code.OPERATOR)) {
			baseUserInfo.put("baseInfo", loginMapper.getUserInfoC(loginSearch));
		}
		else {
			// 고객사 로그인 정보
			if(loginSearch.getUserType() != null && loginSearch.getUserType().equals(Code.CUSTOMER)) {
				baseUserInfo.put("baseInfo", loginMapper.getUserInfoB(loginSearch));
			}// 협력사 로그인정보
			else if(loginSearch.getUserType() != null && loginSearch.getUserType().equals(Code.SUPPLIER)) {
				baseUserInfo.put("baseInfo", loginMapper.getUserInfoS(loginSearch));
			}
			/*else {
				return LoginResultType.FAIL_NOT_EXIST_USER_TYPE;
			}*/
		}

		// 로그인 정보가 다름
		if (baseUserInfo.get("baseInfo") == null) {
			return LoginResultType.FAIL_WRONG_PASSWORD;
		}
		UserInfo userInfo = baseUserInfo.get("baseInfo");

	
		
		// 로그인 비밀번호 틀린 횟수 사용여부
		boolean PasswordFailCountFlag = PropertiesManager.getBoolean("everF.login.PasswordFailCountFlag");
		if( PasswordFailCountFlag ) {
			int WrongLimit = Integer.parseInt(PropertiesManager.getString("everF.login.WrongLimit"));
			if (Integer.parseInt(StringUtils.defaultIfEmpty(userInfo.getPwWrongCnt(), "0")) >= WrongLimit) {
				return LoginResultType.WRONG_PASSWORD_EXCEEDED_CNT;
			}
		}

		if(userInfo.getDateFormat() == null) {
			userInfo.setDateFormat(PropertiesManager.getString("eversrm.default.dateFormat"));
		}
		if(userInfo.getDateValueFormat() == null) {
			userInfo.setDateValueFormat(PropertiesManager.getString("eversrm.default.dateValueFormat"));
		}

		if(!StringUtils.equals(loginSearch.getSessionChange(), "true")) {
			//협력사일경우 최종로그인한 시간 3개월체크
			if(loginSearch.getUserType().equals(Code.SUPPLIER)) {
				if(userInfo.getLastLoginDate() == null) {
				}
			}
		}

		return LoginResultType.SUCCESS;
	}

	@Transactional(propagation = Propagation.REQUIRED, rollbackFor = Exception.class)
	public LoginResultType loginIdCheck(LoginSearch loginSearch) throws Exception {

		String loginAttemptUserType = loginMapper.findUserIdPW(loginSearch);
		Map<String, String> userInfo = new HashMap<String, String>();
		if (StringUtils.isEmpty(loginAttemptUserType)) {
            userInfo.put("GATE_CD", PropertiesManager.getString("eversrm.gateCd.default"));
            userInfo.put("USER_ID", loginSearch.getUserId());

            String userType = loginMapper.getUserType(userInfo);
            userInfo.put("userType", userType);
            if(userType.equals("O")) {
                userInfo.put("USER_TABLE", "STOCUSER");
            } else {
                userInfo.put("USER_TABLE", "STOCCVUR");
            }
            loginMapper.updateWrongPasswordCount(userInfo);

			return LoginResultType.FAIL_NOT_EXIST_ID;
		}
		return LoginResultType.SUCCESS;
	}
	
