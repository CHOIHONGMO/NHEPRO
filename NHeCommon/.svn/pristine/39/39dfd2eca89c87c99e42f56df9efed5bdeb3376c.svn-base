<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.st_ones.eversrm.master.user.MTUB0030_Mapper">

    <select id="mtub0030_doSearch" parameterType="hashmap" resultType="hashmap">

        SELECT
              A.JOB_DATE AS JOB_DATE
            , A.USER_ID AS USER_ID
            , A.USER_NM  AS USER_NM
            , A.SCREEN_ID AS SCREEN_ID
            , <include refid="common.sql.nvl"/>(A.SCREEN_URL, A.SCREEN_NMS) AS SCREEN_NM
            , A.ACTION_CD AS ACTION_CD
            , A.ACTION_NM AS ACTION_NM
            , A.USER_TYPE AS USER_TYPE
            , A.IP_ADDR AS IP_ADDR
            , A.JOB_DESC AS JOB_DESC
        FROM(
            SELECT
                  <include refid="common.sql.toChar"/>(ULOG.JOB_DATE, 'YYYY-MM-DD HH24:MI') AS JOB_DATE
                , ULOG.JOB_DATE AS JOBDATE
                , ULOG.JOB_DESC
                , CASE WHEN ULOG.USER_TYPE = 'N' THEN '' ELSE ULOG.USER_TYPE END AS USER_TYPE
                , ULOG.TMPL_MENU_CD
                , ULOG.USER_ID  AS USER_ID
                , CASE WHEN ULOG.USER_TYPE = 'O'
                      THEN (SELECT  <include refid="common.sql.strDecStart"/>U.USER_NM<include refid="common.sql.strDecEnd"/>  <include refid="common.sql.stringMerge"/>  ' / '    <include refid="common.sql.stringMerge"/>	GETCOMPANYNAME(ULOG.GATE_CD,ULOG.BUYER_CD,'KO')  <include refid="common.sql.stringMerge"/> ' / ' <include refid="common.sql.stringMerge"/> <include refid="common.sql.nvl"/>(<include refid="common.sql.dbo"/>GETDEPTNAME(U.GATE_CD, U.COMPANY_CD, U.DEPT_CD, #{ses.langCd}), '')
                              FROM STOCUSER U
                             WHERE U.GATE_CD = ULOG.GATE_CD
                               AND U.USER_ID = ULOG.USER_ID)
                      WHEN ULOG.USER_TYPE = 'T' <!-- 2022.10.24 개인근로자 파트너스 추가 -->
                      THEN (SELECT  <include refid="common.sql.strDecStart"/>U.USER_NM<include refid="common.sql.strDecEnd"/>  <include refid="common.sql.stringMerge"/>  ' / '    <include refid="common.sql.stringMerge"/>	GETCOMPANYNAME(ULOG.GATE_CD,ULOG.BUYER_CD,'KO')  <include refid="common.sql.stringMerge"/> (CASE WHEN <include refid="common.sql.nvl"/>(REPLACE(U.DEPT_NM,'',null),'X') = 'X' THEN '' ELSE ' / ' <include refid="common.sql.stringMerge"/> <include refid="common.sql.nvl"/>(U.DEPT_NM,'') END)
                              FROM STOCTVUR U
                             WHERE U.GATE_CD = ULOG.GATE_CD
                               AND U.USER_ID =  ULOG.USER_ID)          
                      ELSE (SELECT  <include refid="common.sql.strDecStart"/>U.USER_NM<include refid="common.sql.strDecEnd"/>  <include refid="common.sql.stringMerge"/>  ' / '    <include refid="common.sql.stringMerge"/>	GETCOMPANYNAME(ULOG.GATE_CD,ULOG.BUYER_CD,'KO')  <include refid="common.sql.stringMerge"/> (CASE WHEN <include refid="common.sql.nvl"/>(REPLACE(U.DEPT_NM,'',null),'X') = 'X' THEN '' ELSE ' / ' <include refid="common.sql.stringMerge"/> <include refid="common.sql.nvl"/>(U.DEPT_NM,'') END)
                              FROM STOCCVUR U
                             WHERE U.GATE_CD = ULOG.GATE_CD
                               AND U.USER_ID =  ULOG.USER_ID )
                      END AS USER_NM
                , ULOG.IP_ADDR
                , ULOG.SCREEN_ID AS SCREEN_ID
                , CASE WHEN ULOG.SCREEN_ID IS NOT NULL
                       THEN (SELECT MAX(M.MULTI_NM)
                               FROM STOCMULG M
                              WHERE M.GATE_CD = ULOG.GATE_CD
                                AND M.DEL_FLAG = '0'
                                AND M.MULTI_CD = 'SC'
                                AND M.LANG_CD = #{ses.langCd}
                                AND M.SCREEN_ID = ULOG.SCREEN_ID)
                       ELSE (SELECT MAX(M.MULTI_NM)
                               FROM STOCMULG M
                              WHERE M.GATE_CD = ULOG.GATE_CD
                                AND M.DEL_FLAG = '0'
                                AND M.MULTI_CD = 'MT'
                                AND M.LANG_CD = #{ses.langCd}
                                AND M.SCREEN_ID = ULOG.TMPL_MENU_CD)
                       END AS SCREEN_NMS
                ,(SELECT MAX(<include refid="common.sql.dbo"/>GETCOMCODE(MUTG.GATE_CD, 'M009', MUTG.MODULE_TYPE, '0', #{ses.langCd})
                                <include refid="common.sql.stringMerge"/>'<![CDATA[>]]>'
                                <include refid="common.sql.stringMerge"/><include refid="common.sql.dbo"/>GETMULTINAME(MUTM.GATE_CD, 'MT', #{ses.langCd}, (  SELECT TM.TMPL_MENU_CD
                                                                                                                            FROM STOCMUTM TM
                                                                                                                            WHERE TM.GATE_CD = MUTM.GATE_CD
                                                                                                                            AND TM.TMPL_MENU_CD = ( CASE WHEN (MUTM.HIGH_TMPL_MENU_CD = '' OR MUTM.HIGH_TMPL_MENU_CD IS NULL)
                                                                                                                                                        THEN ''
                                                                                                                                                        ELSE MUTM.HIGH_TMPL_MENU_CD END))
                                                                                                                        , <include refid="common.sql.nvl"/>(null, '-'))  -- GETMULTINAME
                                <include refid="common.sql.stringMerge"/> '<![CDATA[>]]>'
                                <include refid="common.sql.stringMerge"/><include refid="common.sql.dbo"/>GETMULTINAME(MUTM.GATE_CD, 'MT', #{ses.langCd}, MUTM.TMPL_MENU_CD ,CASE WHEN MUTM.SCREEN_ID IS NULL OR MUTM.SCREEN_ID = ''
                                                                                                                                                THEN '-' ELSE MUTM.SCREEN_ID END))
                    FROM STOCMUTM MUTM
                    JOIN STOCMUTG MUTG
                     ON (MUTM.GATE_CD = MUTG.GATE_CD
                     AND MUTM.TMPL_MENU_GROUP_CD = MUTG.TMPL_MENU_GROUP_CD)
                   WHERE MUTM.GATE_CD = ULOG.GATE_CD
                     AND MUTM.SCREEN_ID = ULOG.SCREEN_ID) AS SCREEN_URL
                , <include refid="common.sql.nvl"/>(ULOG.ACTION_CD,'Screen') AS ACTION_CD
                , CASE WHEN <include refid="common.sql.nvl"/>(ULOG.ACTION_CD,'Screen') = 'Screen' THEN <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd},'MP015','menuClick',#{ses.langCd})
                       WHEN ULOG.ACTION_CD = 'Logout' THEN <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd},'MP015','Logout',#{ses.langCd})
                       WHEN ULOG.ACTION_CD = 'Login' THEN <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd},'MP015','Login',#{ses.langCd})
                       WHEN ULOG.ACTION_CD = 'ExcelDownload' THEN <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd},'MP015','ExcelDownload',#{ses.langCd})
                       WHEN ULOG.ACTION_CD = 'menuClick' THEN <include refid="common.sql.dbo"/>GETCODENAME(#{ses.gateCd},'MP015','menuClick',#{ses.langCd})
                       ELSE (SELECT MAX(M.MULTI_NM)
                               FROM STOCMULG M
                              WHERE M.GATE_CD = ULOG.GATE_CD
                                AND M.DEL_FLAG = '0'
                                AND M.MULTI_CD = 'SA'
                                AND M.LANG_CD = #{ses.langCd}
                                AND M.SCREEN_ID = ULOG.SCREEN_ID
                                AND M.ACTION_CD = ULOG.ACTION_CD)
                       END AS ACTION_NM
                , ULOG.GATE_CD
             FROM STOCULOG ULOG
            WHERE ULOG.GATE_CD = #{ses.gateCd}

        <if test="BUYER_CD != '' and BUYER_CD != null">
            AND ULOG.BUYER_CD = #{BUYER_CD}
        </if>

              AND ULOG.JOB_TYPE = 'G'
        ) A
        WHERE 1 = 1
        <if test="ADD_DATE_FROM != '' and ADD_DATE_FROM != null and ADD_DATE_TO != '' and ADD_DATE_TO != null">
        	AND A.JOBDATE <![CDATA[>=]]> <include refid="common.sql.toDateFrom"/>(#{ADD_DATE_FROM})
	        AND A.JOBDATE <![CDATA[<=]]> <include refid="common.sql.toDateTo"/>(#{ADD_DATE_TO})
        </if>
        <if test="USER_TYPE != '' and USER_TYPE != null">
            AND A.USER_TYPE = #{USER_TYPE}
        </if>
        <if test="USER_ID != '' and USER_ID != null">
	         AND UPPER(A.USER_ID) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{USER_ID}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="USER_NM != '' and USER_NM != null">
	         AND UPPER(USER_NM) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{USER_NM}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="IP_ADDR != '' and IP_ADDR != null">
	         AND UPPER(A.IP_ADDR) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{IP_ADDR}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="JOB_DESC != '' and JOB_DESC != null">
	         AND UPPER(A.JOB_DESC) LIKE '%' <include refid="common.sql.stringMerge"/> UPPER(#{JOB_DESC}) <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="SCREEN_ID != '' and SCREEN_ID != null">
            AND <include refid="common.sql.nvl"/>(A.SCREEN_ID, ' ') <include refid="common.sql.stringMerge"/> <include refid="common.sql.nvl"/>(A.TMPL_MENU_CD, ' ') LIKE '%' <include refid="common.sql.stringMerge"/> #{SCREEN_ID} <include refid="common.sql.stringMerge"/> '%'
        </if>
        <if test="ACTION_CD != '' and ACTION_CD != null">
            AND <include refid="common.sql.nvl"/>(<include refid="common.sql.dbo"/>GETMULTINAME(A.GATE_CD, 'SC', #{ses.langCd}, '', A.SCREEN_ID), ' ') <include refid="common.sql.stringMerge"/>
                <include refid="common.sql.nvl"/>(<include refid="common.sql.dbo"/>GETMULTINAME(A.GATE_CD, 'MT', #{ses.langCd}, '', A.TMPL_MENU_CD), ' ')
			    LIKE '%' <include refid="common.sql.stringMerge"/> #{ACTION_CD} <include refid="common.sql.stringMerge"/> '%'
        </if>

        ORDER BY A.JOB_DATE DESC

    </select>

</mapper>