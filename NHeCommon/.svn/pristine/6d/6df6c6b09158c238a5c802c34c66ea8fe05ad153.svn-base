    @RequestMapping(value = "/dirFiles")
    public void dirFiles(EverHttpRequest req, EverHttpResponse resp) throws IOException {

	    String fileList = "";
	    String dir = req.getParameter("dir");
	    if(StringUtils.isNotEmpty(dir)) {
            Iterator<File> fileIterator = org.apache.commons.io.FileUtils.iterateFiles(new File(dir), null, false);
            while(fileIterator.hasNext()) {
                fileList += fileIterator.next().getName()+"<br/>";
            }
        }

        resp.getWriter().write(fileList);
	    resp.setContentType("text/html");
    }

    @Test
    public void testDir() {

        String fileList = "";
        Iterator<File> fileIterator = org.apache.commons.io.FileUtils.iterateFiles(new File("C:/Temp"), null, false);
        while(fileIterator.hasNext()) {
            fileList += fileIterator.next().getName()+"\n";
        }

        logger.info(fileList);
    }

    @RequestMapping(value = "/eformPdfUpload")
    public void eformPdfUpload(EverHttpRequest req, EverHttpResponse resp) throws Exception {
        req.setCharacterEncoding("utf-8"); // 주의:한글 파일명의 경우 flex에서 utf-8로 올려보냄 , euc-kr 일경우 선언 필요

        Map<String, String> param = req.getParamDataMap();
        System.out.println("eformPdfUploadparam" + param.toString());

        String bizType = param.get("bizType");
        String buyerCd = param.get("buyerCd");
        String prBuyerCd = param.get("prBuyerCd");
        String prDeptCd = param.get("prDeptCd");
        String fileName = param.get("fileNm");
        String fileExtension = param.get("fileExtension");
        Integer fileCnt = Integer.parseInt(EverString.isEmpty(param.get("fileCnt"))?"0":param.get("fileCnt"));
        Integer maxFileCnt = Integer.parseInt(EverString.isEmpty(param.get("maxFileCnt"))?"0":param.get("maxFileCnt"));
        String fileType = param.get("fileType");

        if (EverString.isEmpty(bizType)) throw new NoResultException("Biz type is required.");

        // Session의 CompanyCd_DeptCd 를 받아서 폴더를 만든다.
        UserInfo userInfo = (UserInfo)req.getSession().getAttribute("ses");
        String deptCd = StringUtils.isEmpty(userInfo.getDeptCd().trim()) ? "0000" : userInfo.getDeptCd();
        String lastPath = "";

        if (EverString.isNotEmpty(prBuyerCd) && EverString.isNotEmpty(prDeptCd)) {
            lastPath = prBuyerCd + "_" + prDeptCd;
        } else {
            lastPath = userInfo.getCompanyCd() + "_" + deptCd;
        }

        String uuid = req.getParameter("uuid");
        String uuidSeq = null;

        if(EverString.isEmpty(uuid)) {
            uuid = fileAttachService.getUUID();

            synchronized (this) {
                Thread.sleep(2);
                uuidSeq = String.valueOf(System.currentTimeMillis());
            }
        } else {
            Map<String, String> fileInfo = fileAttachService.getFileInfo(uuid, null);
            uuid = fileInfo.get("UUID");
            uuidSeq = fileInfo.get("UUID_SQ");
        }
        
        System.out.println("UUID=========>"+uuid);
        System.out.println("param.CONT_NUM======>"+param.get("CONT_NUM"));
        System.out.println("param.CONT_CNT======>"+param.get("CONT_CNT"));
        
        String tempDirectory = PropertiesManager.getString("oz.source.file.path"); // 파일 임시 저장소
        String targetDirectory = "";
        if(bizType.equals("EC")) {
            targetDirectory = getFileUploadPath(bizType) + bizType + "/" + lastPath + "/"; // 파일 저장소
        } else {
            targetDirectory = getFileUploadPath(bizType) + EverDate.getYear() + "/" + EverDate.getYear()+EverDate.getMonth() + "/" + bizType + "/" + lastPath + "/"; // 파일 저장소
        }

        // 폴더 여부를 확인하여 생성한다.
        EverFile.makeDir(targetDirectory);
        String targetFileNm = uuid + "_" + uuidSeq + "." + fileExtension;
        String tempDirectoryFilePath = tempDirectory + fileExtension + "/" + fileName + "." + fileExtension;
        String targetFilePath = targetDirectory + targetFileNm;

        boolean isEncryptFile = false;
        boolean useFileDecryptionModule = PropertiesManager.getBoolean("everf.file.use.security.module");
        logger.info("첨부파일 암호화 여부가 [{}]로 설정되어 있습니다. ", useFileDecryptionModule);

        File tempFile = new File(tempDirectoryFilePath);
        File targetFile = new File(targetFilePath);

        if(useFileDecryptionModule) {

            String tempFilePath = tempFile.getPath();

            if(DRMUtils.isDRMSupportFile(tempFilePath)) {

                isEncryptFile = DRMUtils.isEncryptedFile(tempFilePath);
                if (isEncryptFile) {

                    logger.info("{}는 암호화된 파일입니다.", tempFilePath);

                    // 파일 존재여부 확인 후 존재하면 삭제
                    if(targetFile.isFile()) {
                        logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                        targetFile.delete();
                    }

                    logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());

                    //FileUtils.copyFile(tempFile, targetFile);
                    checkAndUpdateFile(tempFile, targetFile);
                    if (targetFile.exists()) {
                        logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
                    }

                } else {

                    logger.info("[{}] 파일은 암호화되지 않아 암호화를 진행합니다.", tempFile.getPath());

                    logger.info("-> SRC FILE PATH:" + tempFile.getPath());
                    logger.info("-> TGT FILE PATH:" + targetFile.getPath());

                    // 파일 존재여부 확인 후 존재하면 삭제
                    if(targetFile.isFile()) {
                        logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                        targetFile.delete();
                    }

                    logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());
                    //FileUtils.copyFile(tempFile, targetFile);
                    checkAndUpdateFile(tempFile, targetFile);
                    
                    if (DRMUtils.encryptFile(tempFile.getPath(), targetFile.getPath(), fileName, userInfo)) {
                        if (targetFile.exists()) {
                            logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
                        }
                    }
                }
            } else {

                // 파일 존재여부 확인 후 존재하면 삭제
                if(targetFile.isFile()) {
                    logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                    targetFile.delete();
                }

                logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());
                //FileUtils.copyFile(tempFile, targetFile);
                checkAndUpdateFile(tempFile, targetFile);
                if (targetFile.exists()) {
                    logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
                }
            }

        } else {

            // 파일 존재여부 확인 후 존재하면 삭제
            if(targetFile.isFile()) {
                logger.info("[{}] 파일을 삭제합니다.", targetFile.getPath());
                targetFile.delete();
            }

            logger.info("[{}] 파일을 [{}] 경로로 이동시킵니다.", tempFile.getName(), targetFile.getPath());
            //FileUtils.copyFile(tempFile, targetFile);
            checkAndUpdateFile(tempFile, targetFile);
            if (targetFile.exists()) {
                logger.info("[{}] 파일이 생성되었습니다.", targetFile.getParent());
            }
        }

        String fileSize = EverFile.getFileSize(targetDirectory, uuid + "_" + uuidSeq + "." + fileExtension);

        HashMap<String, String> fileSaveInfo = getFileSaveInfo(bizType, targetDirectory, fileName, fileExtension, uuid, uuidSeq, fileSize, isEncryptFile);

        fileSaveInfo.put("PR_BUYER_CD", (prBuyerCd==null || "".equals(prBuyerCd)) ? userInfo.getCompanyCd() : prBuyerCd   );
        fileSaveInfo.put("PR_DEPT_CD", (prDeptCd==null || "".equals(prDeptCd)) ? userInfo.getDeptCd() : prDeptCd   );

      
        System.out.println("fileSaveInfo: "+ fileSaveInfo.toString());
        if(bizType.equals("EC")) { // 계약서 작성인 경우 파일 해시 값을 저장한다.
            fileSaveInfo.put("HASH_NUM", EverFile.fileToHash(targetFile));
        } //2022.10.04 전자근로계약서 bizType: TC 추가
        else if (bizType.equals("TC")) {
        	fileSaveInfo.put("HASH_NUM", EverFile.fileToHash(targetFile));
        }
        
        System.out.println("HASH_NUM=======>"+EverFile.fileToHash(targetFile));
        if(EverString.isEmpty(req.getParameter("uuid"))) {
            fileAttachService.insertFileInfo(fileSaveInfo);
        } else {
            fileAttachService.updateFileInfo(fileSaveInfo);
        }

        if(fileCnt == maxFileCnt) {
            FileUtils.forceDelete(tempFile);
        }
        if (bizType.equals("EC")) {
            fileSaveInfo.put("CONT_NUM", param.get("CONT_NUM"));
            fileSaveInfo.put("CONT_CNT", param.get("CONT_CNT"));
            fileSaveInfo.put("BUYER_CD", buyerCd);
            fileSaveInfo.put("PR_BUYER_CD", prBuyerCd);
            fileSaveInfo.put("PR_DEPT_CD", prDeptCd);
        }
        //2022.10.04 전자근로계약서 bizType: TC 추가 
        else if (bizType.equals("TC")) {
        	fileSaveInfo.put("CONT_NUM", param.get("CONT_NUM"));
            fileSaveInfo.put("CONT_CNT", param.get("CONT_CNT"));
            fileSaveInfo.put("BUYER_CD", buyerCd);
            fileSaveInfo.put("PR_BUYER_CD", prBuyerCd);
            fileSaveInfo.put("PR_DEPT_CD", prDeptCd);
        }

        resp.sendJSON(fileSaveInfo);
    }

    @RequestMapping(value = "/fileAttach/downloadPdf")
    public void downloadPdf(EverHttpRequest req, EverHttpResponse resp) throws Exception {

        File finalFile = null;
        boolean shouldDecryptFile = false;

        DataInputStream in = null;
        ServletOutputStream op = null;

        try {

            String userAgent = req.getHeader("User-Agent");
            if(org.apache.commons.lang.StringUtils.containsIgnoreCase(userAgent, "android")
                    || org.apache.commons.lang.StringUtils.containsIgnoreCase(userAgent, "iphone")) {

                if(req.getSession().getAttribute("ses") == null) {

                    resp.setContentType("text/html; charset=UTF-8");
                    resp.setCharacterEncoding("utf-8");
                    String domainUrl = PropertiesManager.getString("eversrm.system.domainUrl");
                    resp.getWriter().write("<script type='text/javascript'>location.href='/welcome.so?returnUrl="+URLEncoder.encode(domainUrl+req.getRequestURI()+"?"+req.getQueryString(), "UTF-8")+"';</script>");
                    resp.getWriter().flush();
                    resp.getWriter().close();
                    return;
                }

            }

            if(req.getSession().getAttribute("ses") == null) {
                resp.getWriter().write("<script type='text/javascript'>alert('로그인하셔야 합니다.');</script>");
                resp.getWriter().flush();
                resp.getWriter().close();
                return;
            }

            String uuid = req.getParameter("UUID");
            String uuid_seq = req.getParameter("UUID_SQ");

            Map<String, String> fileInfo = fileAttachService.getFileInfo(uuid, uuid_seq);
            if(fileInfo == null || fileInfo.size() == 0) {
                throw new FileNotFoundException();
            }

            String sourceFile = fileInfo.get("FILE_PATH") + "/" + fileInfo.get("FILE_NM") + "." + fileInfo.get("FILE_EXTENSION");
            String originalFileName = fileInfo.get("REAL_FILE_NM");
            int length = 0;
            ServletContext context = req.getSession().getServletContext();
            String mimeType = context.getMimeType(sourceFile);

            finalFile = new File(sourceFile);
            if (!finalFile.isFile()) {
                logger.error("파일이 존재하지 않습니다: [{}]", sourceFile);
                finalFile = new File(servletContext.getRealPath("/images/noimage.jpg"));
                throw new FileNotFoundException("FILE NOT FOUND");
            }

            boolean useFileDecryptionModule = PropertiesManager.getBoolean("everf.file.use.security.module");
            logger.info("첨부파일 암호화 여부가 [{}]로 설정되어 있습니다. ", useFileDecryptionModule);

            if(useFileDecryptionModule) {
                // 최초 업로드 시 암호화되지 않은 파일의 경우 대외에서 다운로드 시 복호화해서 내려준다.
                if (DRMUtils.isDRMSupportFile(sourceFile)) {
                    logger.info("[{}] 파일은 암호화 대상입니다.", sourceFile);

                    shouldDecryptFile = true;
                }

                // 복호화해서 다운로드할 경우 임시디렉토리에 복호화 파일을 생성해서 다운로드시켜준 후 finally에서 삭제처리한다.
                if (shouldDecryptFile) {

                    logger.info("[{}] 파일은 최초 업로드 시 암호화되어있지 않은 파일이기 때문에 복호화한 후 다운로드 진행합니다.", fileInfo.get("REAL_FILE_NM"));

                    String targetFile = this.getTempFilePath() + fileInfo.get("FILE_NM") + "." + fileInfo.get("FILE_EXTENSION");
                    if (DRMUtils.decryptFile(sourceFile, targetFile)) {
                        logger.info("복호화 결과 코드: {}", "success");
                        finalFile = new File(targetFile);
                    }
                }
            }

            resp.setContentLength((int) finalFile.length());
            resp.setContentType("application/pdf");

            boolean ie = (userAgent.indexOf("MSIE") > -1) || (userAgent.indexOf("Trident") > -1);

            logger.info("userAgent: {}", userAgent);

            String fileName;
            if (ie) {
                fileName = URLEncoder.encode(originalFileName, "UTF-8").replaceAll("\\+", "%20");
            } else {

                StringBuffer sb = new StringBuffer();
                for (int i = 0; i < originalFileName.length(); i++) {
                    char c = originalFileName.charAt(i);
                    if (c > '~') {
                        sb.append(URLEncoder.encode("" + c, "UTF-8"));
                    } else {
                        sb.append(c);
                    }
                }
                fileName = sb.toString();
            }

            resp.setHeader("Content-Disposition", "attachment; filename=\""+ fileName + "." + fileInfo.get("FILE_EXTENSION") +"\"");

//            if (userAgent != null && userAgent.indexOf("MSIE 5.5") > -1) { // MS IE 5.5 이하
//                resp.setHeader("Content-Disposition", "filename=" + URLEncoder.encode(original_filename, "UTF-8").replaceAll("\\+", "%20") + ";");
//            } else if (userAgent != null && userAgent.indexOf("MSIE") > -1) { // MS IE (보통은 6.x 이상 가정)
//                resp.setHeader("Content-Disposition", "attachment; filename=" + java.net.URLEncoder.encode(original_filename, "UTF-8").replaceAll("\\+", "%20") + ";");
//            } else { // 모질라나 오페라
//                resp.setHeader("Content-Disposition", "attachment; filename=" + new String(original_filename.getBytes("UTF-8"), "latin1").replaceAll("\\+", "%20") + ";");
//            }


            try {
                op = resp.getOutputStream();
                byte[] bbuf = new byte[4096];

                // 협력업체용 참부파일 (BID (입찰), BOARD(공지사항), CONT(계약) )
//            in = new DataInputStream(new ByteArrayInputStream(binaryfile));
//            if (PropertiesManager.getString("everf.file.binary.bizTypes").indexOf(fileInfo.get("BIZ_TYPE")) >= 0) {
//
//            } else {
                in = new DataInputStream(new FileInputStream(finalFile));
//            }
                while ((length = in.read(bbuf)) != -1) {
                    op.write(bbuf, 0, length);
                    op.flush();
                }
            } catch(Exception e) {
                logger.error(e.getMessage());
            } finally {
                if(in != null) {
                    in.close();
                }
                if(op != null) {
                    op.close();
                }
            }

        } catch(FileNotFoundException fne) {
            logger.error(fne.getMessage(), fne);
            resp.setContentType("text/html; charset=UTF-8");
            resp.setCharacterEncoding("utf-8");
            resp.getWriter().write("<script type='text/javascript'>alert('첨부파일이 존재하지 않습니다.');</script>");
        } catch (Exception e) {
            logger.error(e.getMessage(), e);
            resp.setContentType("text/html; charset=UTF-8");
            resp.setCharacterEncoding("utf-8");
            resp.getWriter().write("<script type='text/javascript'>alert('잘못된 접근을 시도했거나 서버에서 오류가 발생했습니다.\\n관리자에게 문의바랍니다.');</script>");
        } finally {

			/*
			 * if(shouldDecryptFile) { boolean deleteStatus = finalFile.delete();
			 * if(deleteStatus) { logger.info("[{}] 복호화된 파일을 삭제처리했습니다.",
			 * finalFile.getPath()); } else { logger.info("[{}] 복호화된 파일을 삭제하지 못했습니다.",
			 * finalFile.getPath()); } }
			 */

            if(op != null) {
                op.flush();
            }
            if(in != null) {
                in.close();
            }
            if(op != null) {
                op.close();
            }
        }
    }

    @RequestMapping(value = "/fileAttach/viewPdf")
    public void viewPdf(EverHttpRequest req, EverHttpResponse resp) throws Exception {

        File finalFile = null;
        boolean shouldDecryptFile = false;

        DataInputStream in = null;
        ServletOutputStream op = null;
        try {

            String userAgent = req.getHeader("User-Agent");
            if(org.apache.commons.lang.StringUtils.containsIgnoreCase(userAgent, "android") || org.apache.commons.lang.StringUtils.containsIgnoreCase(userAgent, "iphone"))
            {
                if(req.getSession().getAttribute("ses") == null) {
                    resp.setContentType("text/html; charset=UTF-8");
                    resp.setCharacterEncoding("utf-8");
                    String domainUrl = PropertiesManager.getString("eversrm.system.domainUrl");
                    resp.getWriter().write("<script type='text/javascript'>location.href='/welcome.so?returnUrl="+URLEncoder.encode(domainUrl+req.getRequestURI()+"?"+req.getQueryString(), "UTF-8")+"';</script>");
                    resp.getWriter().flush();
                    resp.getWriter().close();
                    return;
                }
            }

            if(req.getSession().getAttribute("ses") == null) {
                resp.getWriter().write("<script type='text/javascript'>alert('로그인하셔야 합니다.');</script>");
                resp.getWriter().flush();
                resp.getWriter().close();
                return;
            }

            String uuid = req.getParameter("UUID");
            String uuid_seq = req.getParameter("UUID_SQ");

            Map<String, String> fileInfo = fileAttachService.getFileInfo(uuid, uuid_seq);
            if(fileInfo == null || fileInfo.size() == 0) {
                throw new FileNotFoundException();
            }

            String sourceFile = fileInfo.get("FILE_PATH") + "/" + fileInfo.get("FILE_NM") + "." + fileInfo.get("FILE_EXTENSION");
            String originalFileName = fileInfo.get("REAL_FILE_NM");
            int length = 0;
            ServletContext context = req.getSession().getServletContext();
            String mimeType = context.getMimeType(sourceFile);

            finalFile = new File(sourceFile);
            if (!finalFile.isFile()) {
                logger.error("파일이 존재하지 않습니다: [{}]", sourceFile);
                finalFile = new File(servletContext.getRealPath("/images/noimage.jpg"));
                throw new FileNotFoundException("FILE NOT FOUND");
            }

            boolean useFileDecryptionModule = PropertiesManager.getBoolean("everf.file.use.security.module");
            logger.info("첨부파일 암호화 여부가 [{}]로 설정되어 있습니다. ", useFileDecryptionModule);

            if(useFileDecryptionModule) {
                // 최초 업로드 시 암호화되지 않은 파일의 경우 대외에서 다운로드 시 복호화해서 내려준다.
                if (DRMUtils.isDRMSupportFile(sourceFile)) {
                    logger.info("[{}] 파일은 암호화 대상입니다.", sourceFile);
                    shouldDecryptFile = true;
                }

                // 복호화해서 다운로드할 경우 임시디렉토리에 복호화 파일을 생성해서 다운로드시켜준 후 finally에서 삭제처리한다.
                if (shouldDecryptFile) {
                    logger.info("[{}] 파일은 최초 업로드 시 암호화되어있지 않은 파일이기 때문에 복호화한 후 다운로드 진행합니다.", fileInfo.get("REAL_FILE_NM"));
                    String targetFile = this.getTempFilePath() + fileInfo.get("FILE_NM") + "." + fileInfo.get("FILE_EXTENSION");
                    if (DRMUtils.decryptFile(sourceFile, targetFile)) {
                        logger.info("복호화 결과 코드: {}", "success");
                        finalFile = new File(targetFile);
                    }
                }
            }

            resp.setContentLength((int) finalFile.length());
            resp.setContentType("application/pdf");
            boolean ie = (userAgent.indexOf("MSIE") > -1) || (userAgent.indexOf("Trident") > -1);
            logger.info("userAgent: {}", userAgent);

            String fileName;
            if (ie) {
                fileName = URLEncoder.encode(originalFileName, "UTF-8").replaceAll("\\+", "%20");
            } else {

                StringBuffer sb = new StringBuffer();
                for (int i = 0; i < originalFileName.length(); i++) {
                    char c = originalFileName.charAt(i);
                    if (c > '~') {
                        sb.append(URLEncoder.encode("" + c, "UTF-8"));
                    } else {
                        sb.append(c);
                    }
                }
                fileName = sb.toString();
            }

            // pdf 파일을 직접 보여준다
            resp.setHeader("Content-Disposition", "inline; filename=\""+ fileName + "." + fileInfo.get("FILE_EXTENSION") +"\"");
            try {
                op = resp.getOutputStream();
                byte[] bbuf = new byte[4096];

                in = new DataInputStream(new FileInputStream(finalFile));
                while ((length = in.read(bbuf)) != -1) {
                    op.write(bbuf, 0, length);
                    op.flush();
                }
            }
            catch(Exception e) {
                logger.error(e.getMessage());
            }
            finally {
                if(in != null) {
                    in.close();
                }
                if(op != null) {
                    op.close();
                }
            }
        }
        catch(FileNotFoundException fne) {
            logger.error(fne.getMessage(), fne);
            resp.setContentType("text/html; charset=UTF-8");
            resp.setCharacterEncoding("utf-8");
            resp.getWriter().write("<script type='text/javascript'>alert('첨부파일이 존재하지 않습니다.');</script>");
        }
        catch (Exception e) {
            logger.error(e.getMessage(), e);
            resp.setContentType("text/html; charset=UTF-8");
            resp.setCharacterEncoding("utf-8");
            resp.getWriter().write("<script type='text/javascript'>alert('잘못된 접근을 시도했거나 서버에서 오류가 발생했습니다.\\n관리자에게 문의바랍니다.');</script>");
        }
        finally {
			/*
			 * if(shouldDecryptFile) { boolean deleteStatus = finalFile.delete();
			 * if(deleteStatus) { logger.info("[{}] 복호화된 파일을 삭제처리했습니다.",
			 * finalFile.getPath()); } else { logger.info("[{}] 복호화된 파일을 삭제하지 못했습니다.",
			 * finalFile.getPath()); } }
			 */
            if(op != null) {
                op.flush();
            }
            if(in != null) {
                in.close();
            }
            if(op != null) {
                op.close();
            }
        }
    }
    
