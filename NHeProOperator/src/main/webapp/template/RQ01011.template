		<table style='width:100%;font-weight:normal;border:0;border-collapse:collapse;border-spacing:0;table-layout:fixed;border-top:2px solid #027bc2'>
			<colgroup>
				<col style="width:23%">
				<col style="width:36%">
				<col style="width:17%">
				<col style="width:17%">
				<col style="width:7%">
